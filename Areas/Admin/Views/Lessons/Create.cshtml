@model ELearningWebsite.Models.Lesson
@{
    ViewData["Title"] = "Tạo bài học mơi";
    var chapterId = Context.Request.Query["chapterId"].ToString();
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="admin-title">
            <i class="fas fa-plus-circle text-success"></i>
            Tạo bài học mơi
        </h2>
        <a href="/Admin/Lessons" class="admin-btn admin-btn-secondary">
            <i class="fas fa-arrow-left me-2"></i>
            Quay lại danh sách
        </a>
    </div>

    <div class="admin-card">
        <div class="card-body">
            <form asp-action="Create" method="post">
                <div class="form-group">
                    <label for="ChapterId">Chương</label>
                    <select asp-for="ChapterId" class="form-select">
                        <option value="">-- Chọn chương --</option>
                        @if (ViewBag.Chapters != null)
                        {
                            foreach (var chapter in (List<ELearningWebsite.Models.Chapter>)ViewBag.Chapters)
                            {
                                <option value="@chapter.Id" selected="@(Model.ChapterId == chapter.Id ? "selected" : null)">@chapter.Name</option>
                            }
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label asp-for="Title" class="form-label">Tên bài học</label>
                    <input asp-for="Title" class="form-control" />
                </div>
                <div class="form-group">
                    <label asp-for="Description" class="form-label">Mô tả</label>
                    <textarea asp-for="Description" class="form-control"></textarea>
                </div>
                <div class="form-group">
                    <label asp-for="Content" class="form-label">Nội dung chi tiết</label>
                    <textarea asp-for="Content" class="form-control"></textarea>
                </div>
                <div class="form-group">
                    <label class="form-label">Chọn Video</label>
                    <div class="d-flex gap-2 align-items-start">
                        <button type="button" class="btn btn-outline-primary" id="btnSelectVideo" data-bs-toggle="modal" data-bs-target="#mediaPickerModal">
                            <i class="fas fa-video me-2"></i>Chọn từ Media Library
                        </button>
                        <div class="flex-grow-1">
                            <div id="selectedVideoInfo" class="alert alert-info d-none" role="alert">
                                <strong>Video được chọn:</strong> <span id="selectedVideoName"></span>
                                <br />
                                <small id="selectedVideoDetails"></small>
                            </div>
                        </div>
                    </div>
                    <input asp-for="VideoUrl" class="form-control mt-2" placeholder="Hoặc nhập URL trực tiếp" />
                </div>
                <div class="form-group">
                    <label asp-for="Duration" class="form-label">Thời lượng (phút)</label>
                    <input asp-for="Duration" type="number" class="form-control" min="0" />
                </div>
                <div class="form-group">
                    <label asp-for="OrderIndex" class="form-label">Thứ tự hiăn thị</label>
                    <input asp-for="OrderIndex" type="number" class="form-control" min="1" />
                </div>
                <div class="form-group">
                    <label asp-for="Type" class="form-label">Loại nội dung</label>
                    <select asp-for="Type" class="form-select">
                        <option value="Video">Video</option>
                        <option value="Text">Text</option>
                        <option value="Quiz">Quiz</option>
                        <option value="Assignment">Assignment</option>
                    </select>
                </div>
                <div class="form-group">
                    <label asp-for="Status" class="form-label">Trạng thái</label>
                    <select asp-for="Status" class="form-select">
                        <option value="Active">Active</option>
                        <option value="Draft">Draft</option>
                        <option value="Archived">Archived</option>
                    </select>
                </div>
                <div class="form-actions mt-3">
                    <button type="submit" class="btn btn-success">
                        <i class="fas fa-save"></i> Tạo bài học
                    </button>
                    <a href="/Admin/Lessons" class="btn btn-secondary">
                        <i class="fas fa-times"></i> Hủy
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Media Picker Modal -->
<div class="modal fade" id="mediaPickerModal" tabindex="-1" aria-labelledby="mediaPickerModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="mediaPickerModalLabel">Chọn Video từ Media Library</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="videoPickerBreadcrumbs" class="mb-3 small"></div>
                <div id="videoLoadingSpinner" class="text-center d-none">
                    <div class="spinner-border" role="status">
                        <span class="visually-hidden">Đang tải...</span>
                    </div>
                </div>
                <div id="folderList" class="list-group mb-3"></div>
                <div id="videoList" class="row g-2"></div>
                <div id="pickerHint" class="text-muted small d-none">Chọn thư mục để đi sâu hơn, sau đó chọn video.</div>
                <div id="pickerErrorMsg" class="alert alert-danger d-none mt-3"></div>
                <div id="noVideosMsg" class="alert alert-warning d-none mt-3">
                    Không có thư mục hoặc video trong vị trí hiện tại.
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    (function () {
        const videoUrlInput = document.querySelector('[name="VideoUrl"]');
        const btnSelectVideo = document.getElementById('btnSelectVideo');
        const mediaPickerModal = document.getElementById('mediaPickerModal');
        const folderList = document.getElementById('folderList');
        const videoList = document.getElementById('videoList');
        const breadcrumbs = document.getElementById('videoPickerBreadcrumbs');
        const pickerHint = document.getElementById('pickerHint');
        const pickerErrorMsg = document.getElementById('pickerErrorMsg');
        const noVideosMsg = document.getElementById('noVideosMsg');
        const videoLoadingSpinner = document.getElementById('videoLoadingSpinner');
        const selectedVideoInfo = document.getElementById('selectedVideoInfo');
        const selectedVideoName = document.getElementById('selectedVideoName');
        const selectedVideoDetails = document.getElementById('selectedVideoDetails');

        if (!mediaPickerModal) return;

        const modal = new bootstrap.Modal(mediaPickerModal);
        let currentFolderId = null;

        const escapeHtml = function (value) {
            return (value || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
        };

        const showLoading = function () {
            videoLoadingSpinner.classList.remove('d-none');
            pickerErrorMsg.classList.add('d-none');
            noVideosMsg.classList.add('d-none');
            pickerHint.classList.add('d-none');
            folderList.innerHTML = '';
            videoList.innerHTML = '';
            breadcrumbs.innerHTML = '';
        };

        const renderBreadcrumbs = function (items) {
            const html = (items || []).map((item, index) => {
                const isLast = index === items.length - 1;
                const text = escapeHtml(item.name);
                if (isLast) {
                    return '<span class="fw-semibold">' + text + '</span>';
                }
                const idValue = item.id == null ? '' : String(item.id);
                return '<a href="#" class="video-breadcrumb-link text-decoration-none" data-folder-id="' + idValue + '">' + text + '</a>';
            }).join(' <span class="mx-2 text-muted">/</span> ');
            breadcrumbs.innerHTML = html;

            breadcrumbs.querySelectorAll('.video-breadcrumb-link').forEach(function (link) {
                link.addEventListener('click', function (e) {
                    e.preventDefault();
                    const raw = this.getAttribute('data-folder-id');
                    currentFolderId = raw ? parseInt(raw, 10) : null;
                    loadNode(currentFolderId);
                });
            });
        };

        const renderFolders = function (items) {
            if (!items || items.length === 0) {
                folderList.innerHTML = '';
                return;
            }

            folderList.innerHTML = items.map(function (folder) {
                return '<button type="button" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center video-folder-item" data-folder-id="' + folder.id + '">'
                    + '<span><i class="fas fa-folder text-warning me-2"></i>' + escapeHtml(folder.name) + '</span>'
                    + '<span class="badge bg-light text-dark">' + folder.itemCount + '</span>'
                    + '</button>';
            }).join('');

            folderList.querySelectorAll('.video-folder-item').forEach(function (button) {
                button.addEventListener('click', function () {
                    currentFolderId = parseInt(this.getAttribute('data-folder-id'), 10);
                    loadNode(currentFolderId);
                });
            });
        };

        const renderVideos = function (items) {
            if (!items || items.length === 0) {
                videoList.innerHTML = '';
                return;
            }

            videoList.innerHTML = items.map(function (video) {
                return '<div class="col-md-6 col-lg-4">'
                    + '<div class="card h-100 video-selector-card" data-select-url="' + escapeHtml(video.selectUrl) + '" data-name="' + escapeHtml(video.name) + '" data-meta="' + escapeHtml(video.sizeDisplay + ' • ' + video.createdAt) + '" style="cursor: pointer; transition: all 0.2s;">'
                    + '<div class="card-body">'
                    + '<div class="d-flex align-items-start gap-2">'
                    + '<div><i class="fas fa-video" style="font-size: 32px; color: #007bff;"></i></div>'
                    + '<div class="flex-grow-1">'
                    + '<h6 class="card-title text-truncate" title="' + escapeHtml(video.name) + '">' + escapeHtml(video.name) + '</h6>'
                    + '<small class="text-muted d-block">' + escapeHtml(video.sizeDisplay) + '</small>'
                    + '<small class="text-muted d-block">' + escapeHtml(video.createdAt) + '</small>'
                    + '</div></div></div></div></div>';
            }).join('');

            videoList.querySelectorAll('.video-selector-card').forEach(function (card) {
                card.addEventListener('click', function () {
                    videoUrlInput.value = this.getAttribute('data-select-url');
                    selectedVideoName.textContent = this.getAttribute('data-name');
                    selectedVideoDetails.textContent = this.getAttribute('data-meta');
                    selectedVideoInfo.classList.remove('d-none');
                    modal.hide();
                });
            });
        };

        const loadNode = async function (folderId) {
            showLoading();

            try {
                const url = '@Url.Action("Browse", "MediaLibrary", new { area = "Admin" })' + (folderId ? ('?folderId=' + folderId) : '');
                const response = await fetch(url, { headers: { 'Accept': 'application/json' } });
                if (!response.ok) {
                    throw new Error('Không tải được dữ liệu. Mã lỗi: ' + response.status);
                }

                const data = await response.json();
                videoLoadingSpinner.classList.add('d-none');

                renderBreadcrumbs(data.breadcrumbs || []);
                renderFolders(data.folders || []);
                renderVideos(data.videos || []);

                const hasFolders = (data.folders || []).length > 0;
                const hasVideos = (data.videos || []).length > 0;
                pickerHint.classList.toggle('d-none', !(hasFolders && !hasVideos));
                noVideosMsg.classList.toggle('d-none', hasFolders || hasVideos);
            } catch (error) {
                videoLoadingSpinner.classList.add('d-none');
                pickerErrorMsg.textContent = error.message || 'Có lỗi xảy ra khi tải Media Library.';
                pickerErrorMsg.classList.remove('d-none');
            }
        };

        const openPickerRoot = async function () {
            currentFolderId = null;
            await loadNode(currentFolderId);
        };

        if (btnSelectVideo) {
            btnSelectVideo.addEventListener('click', openPickerRoot);
        }

        mediaPickerModal.addEventListener('show.bs.modal', openPickerRoot);

        // Show selected video info if already has VideoUrl
        if (videoUrlInput && videoUrlInput.value) {
            const videoName = videoUrlInput.value.split('/').pop();
            selectedVideoName.textContent = videoName;
            selectedVideoInfo.classList.remove('d-none');
        }

        openPickerRoot();
    })();
</script>
}
