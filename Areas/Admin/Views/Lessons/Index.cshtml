@model IEnumerable<ELearningWebsite.Models.Lesson>
@{
    ViewData["Title"] = "Danh sách bài học";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="admin-title">
            <i class="fas fa-book me-2"></i>
            Danh sách bài học
        </h2>
        <a href="/Admin/Lessons/Create" class="admin-btn admin-btn-primary">
            <i class="fas fa-plus me-2"></i>
            Thêm bài học mơi
        </a>
    </div>

    <div class="admin-card mb-3">
        <div class="card-body">
            <form method="get" asp-action="Index" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label">Khóa học</label>
                    <select name="courseId" class="form-select">
                        <option value="">-- Tất cả khóa học --</option>
                        @if (ViewBag.Courses != null)
                        {
                            foreach (var course in ViewBag.Courses)
                            {
                                <option value="@course.Id" selected="@(ViewBag.SelectedCourseId != null && ViewBag.SelectedCourseId == course.Id)">@course.Title</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Chương</label>
                    <select name="chapterId" class="form-select">
                        <option value="">-- Tất cả chương --</option>
                        @if (ViewBag.Chapters != null)
                        {
                            foreach (var chapter in ViewBag.Chapters)
                            {
                                <option value="@chapter.Id" selected="@(ViewBag.SelectedChapterId != null && ViewBag.SelectedChapterId == chapter.Id)">@chapter.Name</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Bài học</label>
                    <input type="text" name="lessonKeyword" class="form-control" value="@ViewBag.LessonKeyword" placeholder="Nhập tên bài học..." />
                </div>
                <div class="col-md-1 d-grid">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-search"></i>
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="admin-card">
        <div class="card-body">
            <table class="table table-bordered table-hover">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Tên bài học</th>
                        <th>Khóa học</th>
                        <th>Chương</th>
                        <th>Loại</th>
                        <th>Thứ tự</th>
                        <th>Trạng thái</th>
                        <th>Ngày tạo</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var lesson in Model)
                    {
                        <tr>
                            <td>@lesson.Id</td>
                            <td>@lesson.Title</td>
                            <td>@lesson.Chapter?.Course?.Title</td>
                            <td>@lesson.Chapter?.Name</td>
                            <td>@lesson.Type</td>
                            <td>@lesson.OrderIndex</td>
                            <td>@lesson.Status</td>
                            <td>@lesson.CreatedAt.ToString("dd/MM/yyyy")</td>
                            <td>
                                <a href="/Admin/Lessons/Details/@lesson.Id" class="btn btn-sm btn-primary">Xem</a>
                                <a href="/Admin/Lessons/Edit/@lesson.Id" class="btn btn-sm btn-warning">Sửa</a>
                                <a href="/Admin/Lessons/Quiz?lessonId=@lesson.Id" class="btn btn-sm btn-info">Bai tap</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
