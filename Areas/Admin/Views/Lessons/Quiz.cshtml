@model ELearningWebsite.Models.Quiz
@{
    var lesson = ViewBag.Lesson as ELearningWebsite.Models.Lesson;
    ViewData["Title"] = "Quan ly bai tap trac nghiem";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="admin-title">
            <i class="fas fa-list-check me-2"></i>
            Quan ly bai tap - @(lesson?.Title ?? "")
        </h2>
        <a href="/Admin/Lessons" class="btn btn-secondary">Quay lai danh sach bai hoc</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="card mb-4">
        <div class="card-header"><strong>Thong tin bai tap</strong></div>
        <div class="card-body">
            <form method="post" action="/Admin/Lessons/CreateQuiz">
                @Html.AntiForgeryToken()
                <input type="hidden" name="lessonId" value="@lesson?.Id" />
                <div class="row g-3">
                    <div class="col-md-7">
                        <label class="form-label">Tieu de bai tap</label>
                        <input name="title" class="form-control" value="@(Model?.Title ?? $"Quiz - {lesson?.Title}")" required />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Nguong dat (%)</label>
                        <input name="passPercent" class="form-control" type="number" min="1" max="100" value="@(Model?.PassPercent ?? 80)" required />
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <button type="submit" class="btn btn-primary w-100">Luu quiz</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    @if (Model != null)
    {
        <div class="card mb-4">
            <div class="card-header"><strong>Them cau hoi</strong></div>
            <div class="card-body">
                <form method="post" action="/Admin/Lessons/AddQuestion">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="quizId" value="@Model.Id" />
                    <div class="row g-3">
                        <div class="col-md-8">
                            <input name="content" class="form-control" placeholder="Nhap noi dung cau hoi" required />
                        </div>
                        <div class="col-md-2">
                            <input name="orderIndex" class="form-control" type="number" min="1" value="1" />
                        </div>
                        <div class="col-md-2">
                            <button type="submit" class="btn btn-success w-100">Them cau hoi</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        @foreach (var question in Model.Questions.OrderBy(q => q.OrderIndex))
        {
            <div class="card mb-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <div><strong>Cau @question.OrderIndex:</strong> @question.Content</div>
                    <form method="post" action="/Admin/Lessons/DeleteQuestion" onsubmit="return confirm('Xoa cau hoi nay?');">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="questionId" value="@question.Id" />
                        <button class="btn btn-sm btn-danger" type="submit">Xoa cau hoi</button>
                    </form>
                </div>
                <div class="card-body">
                    <div class="table-responsive mb-3">
                        <table class="table table-sm table-bordered">
                            <thead>
                                <tr>
                                    <th style="width: 60px;">Thu tu</th>
                                    <th>Dap an</th>
                                    <th style="width: 100px;">Dung</th>
                                    <th style="width: 140px;">Chon dap an dung</th>
                                    <th style="width: 100px;">Xoa</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var ans in question.Answers.OrderBy(a => a.OrderIndex))
                                {
                                    <tr>
                                        <td>@ans.OrderIndex</td>
                                        <td>@ans.AnswerText</td>
                                        <td>
                                            @if (ans.IsCorrect)
                                            {
                                                <span class="badge bg-success">Dung</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Sai</span>
                                            }
                                        </td>
                                        <td>
                                            <form method="post" action="/Admin/Lessons/SetCorrectAnswer">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="answerId" value="@ans.Id" />
                                                <button class="btn btn-sm btn-outline-success" type="submit" @(ans.IsCorrect ? "disabled" : null)>
                                                    Chon dung
                                                </button>
                                            </form>
                                        </td>
                                        <td>
                                            <form method="post" action="/Admin/Lessons/DeleteAnswer" onsubmit="return confirm('Xoa dap an nay?');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="answerId" value="@ans.Id" />
                                                <button class="btn btn-sm btn-outline-danger" type="submit">Xoa</button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <button class="btn btn-outline-primary btn-sm mb-2" type="button" data-bs-toggle="collapse" data-bs-target="#addAnswer_@question.Id" aria-expanded="false">
                        <i class="fas fa-plus me-1"></i>Them dap an cho cau hoi
                    </button>
                    <div class="collapse" id="addAnswer_@question.Id">
                        <form method="post" action="/Admin/Lessons/AddAnswer">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="questionId" value="@question.Id" />
                            <div class="row g-2 align-items-center">
                                <div class="col-md-7">
                                    <input name="answerText" class="form-control" placeholder="Nhap dap an" required />
                                </div>
                                <div class="col-md-2">
                                    <input name="orderIndex" class="form-control" type="number" min="1" value="1" />
                                </div>
                                <div class="col-md-2 form-check mt-2">
                                    <input name="isCorrect" class="form-check-input" type="checkbox" value="true" id="correct_@question.Id" />
                                    <label class="form-check-label" for="correct_@question.Id">Dap an dung</label>
                                </div>
                                <div class="col-md-1">
                                    <button type="submit" class="btn btn-primary w-100">Them</button>
                                </div>
                            </div>
                            <div class="form-text">Co the them dap an thuong, sau do bam "Chon dung" de dat dap an dung.</div>
                        </form>
                    </div>
                </div>
            </div>
        }
    }
</div>
