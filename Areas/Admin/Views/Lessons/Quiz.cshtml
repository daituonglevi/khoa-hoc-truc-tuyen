@model ELearningWebsite.Models.Quiz
@{
    var lesson = ViewBag.Lesson as ELearningWebsite.Models.Lesson;
    ViewData["Title"] = "Quản lý bài tập trắc nghiệm- " + (lesson?.Title ?? "");
}
    
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="admin-title">
            <i class="fas fa-list-check me-2"></i>
            Quản lý bài tập - @(lesson?.Title ?? "")
        </h2>
        <a href="/Admin/Lessons" class="btn btn-secondary">Quay lại danh sách bài học</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="card mb-4">
        <div class="card-header"><strong>Thông tin bài tập</strong></div>
        <div class="card-body">
            <form method="post" action="/Admin/Lessons/CreateQuiz">
                @Html.AntiForgeryToken()
                <input type="hidden" name="lessonId" value="@lesson?.Id" />
                <div class="row g-3">
                    <div class="col-md-7">
                        <label class="form-label">Tiêu đề bài tập</label>
                        <input name="title" class="form-control" value="@(Model?.Title ?? $"Quiz - {lesson?.Title}")" required />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Ngưỡng đạt (%)</label>
                        <input name="passPercent" class="form-control" type="number" min="1" max="100" value="@(Model?.PassPercent ?? 80)" required />
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <button type="submit" class="btn btn-primary w-100">Lưu quiz</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    @if (Model != null)
    {
        <div class="card mb-4">
            <div class="card-header"><strong>Thêm câu hỏi</strong></div>
            <div class="card-body">
                <form method="post" action="/Admin/Lessons/AddQuestion">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="quizId" value="@Model.Id" />
                    <div class="row g-3">
                        <div class="col-md-8">
                            <input name="content" class="form-control" placeholder="Nhập nội dung câu hỏi" required />
                        </div>
                        <div class="col-md-2">
                            <input name="orderIndex" class="form-control" type="number" min="1" value="1" />
                        </div>
                        <div class="col-md-2">
                            <button type="submit" class="btn btn-success w-100">Thêm câu hỏi</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        @foreach (var question in Model.Questions.OrderBy(q => q.OrderIndex))
        {
            <div class="card mb-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <div><strong>Câu @question.OrderIndex:</strong> @question.Content</div>
                    <form method="post" action="/Admin/Lessons/DeleteQuestion" onsubmit="return confirm('Bạn có chắc chắn muốn xóa câu hỏi này?');">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="questionId" value="@question.Id" />
                        <button class="btn btn-sm btn-danger" type="submit">Xóa câu hỏi</button>
                    </form>
                </div>
                <div class="card-body">
                    <div class="table-responsive mb-3">
                        <table class="table table-sm table-bordered">
                            <thead>
                                <tr>
                                    <th style="width: 60px;">Thứ tự</th>
                                    <th>Đáp án</th>
                                    <th style="width: 100px;">Đúng</th>
                                    <th style="width: 140px;">Chọn đáp án đúng</th>
                                    <th style="width: 100px;">Xóa</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var ans in question.Answers.OrderBy(a => a.OrderIndex))
                                {
                                    <tr>
                                        <td>@ans.OrderIndex</td>
                                        <td>@ans.AnswerText</td>
                                        <td>
                                            @if (ans.IsCorrect)
                                            {
                                                <span class="badge bg-success">Đúng</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Sai</span>
                                            }
                                        </td>
                                        <td>
                                            <form method="post" action="/Admin/Lessons/SetCorrectAnswer">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="answerId" value="@ans.Id" />
                                                <button class="btn btn-sm btn-outline-success" type="submit" @(ans.IsCorrect ? "disabled" : null)>
                                                    Chọn đúng
                                                </button>
                                            </form>
                                        </td>
                                        <td>
                                            <form method="post" action="/Admin/Lessons/DeleteAnswer" onsubmit="return confirm('Bạn có chắc chắn muốn xóa đáp án này?');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="answerId" value="@ans.Id" />
                                                <button class="btn btn-sm btn-outline-danger" type="submit">Xóa</button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <button class="btn btn-outline-primary btn-sm mb-2" type="button" data-bs-toggle="collapse" data-bs-target="#addAnswer_@question.Id" aria-expanded="false">
                        <i class="fas fa-plus me-1"></i>Thêm đáp án cho câu hỏi
                    </button>
                    <div class="collapse" id="addAnswer_@question.Id">
                        <form method="post" action="/Admin/Lessons/AddAnswer">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="questionId" value="@question.Id" />
                            <div class="row g-2 align-items-center">
                                <div class="col-md-7">
                                    <input name="answerText" class="form-control" placeholder="Nhập đáp án" required />
                                </div>
                                <div class="col-md-2">
                                    <input name="orderIndex" class="form-control" type="number" min="1" value="1" />
                                </div>
                                <div class="col-md-2 form-check mt-2">
                                    <input name="isCorrect" class="form-check-input" type="checkbox" value="true" id="correct_@question.Id" />
                                    <label class="form-check-label" for="correct_@question.Id">Đáp án đúng</label>
                                </div>
                                <div class="col-md-1">
                                    <button type="submit" class="btn btn-primary w-100">Thêm</button>
                                </div>
                            </div>
                            <div class="form-text">Có thể thêm đáp án thường, sau đó bấm "Chọn đúng" để đặt đáp án đúng.</div>
                        </form>
                    </div>
                </div>
            </div>
        }
    }
</div>
