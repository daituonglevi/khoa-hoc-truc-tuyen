@page
@model ELearningWebsite.Areas.Identity.Pages.Account.ResetPasswordModel
@{
    ViewData["Title"] = "Đặt lại mật khẩu";
}

<div class="container py-5 mt-4">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="bg-white p-4 p-md-5 rounded-4 border" style="box-shadow: 0 4px 24px rgba(0,0,0,0.04);">
                <div class="text-center mb-4">
                    <div class="d-inline-flex align-items-center justify-content-center bg-light rounded-circle mb-3" style="width: 64px; height: 64px;">
                        <i class="fas fa-unlock-alt text-secondary fs-4"></i>
                    </div>
                    <h3 class="fw-bold mb-2" style="font-family: inherit;">Đặt lại mật khẩu</h3>
                    <p class="text-muted small">
                        Vui lòng nhập mật khẩu mới cho tài khoản của bạn.
                    </p>
                </div>
                
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>
                    <input asp-for="Input.Code" type="hidden" />
                    
                    <div class="mb-4">
                        <label asp-for="Input.Email" class="form-label fw-medium small text-dark">
                            Địa chỉ email
                        </label>
                        <input asp-for="Input.Email" class="form-control form-control-lg border-light-subtle rounded-3 fs-6" placeholder="name@example.com" />
                        <span asp-validation-for="Input.Email" class="text-danger small mt-1 d-block"></span>
                    </div>
                    
                    <div class="mb-4">
                        <label asp-for="Input.Password" class="form-label fw-medium small text-dark">
                            Mật khẩu mới
                        </label>
                        <input asp-for="Input.Password" class="form-control form-control-lg border-light-subtle rounded-3 fs-6" placeholder="Nhập mật khẩu mới" />
                        <span asp-validation-for="Input.Password" class="text-danger small mt-1 d-block"></span>
                    </div>
                    
                    <div class="mb-4">
                        <label asp-for="Input.ConfirmPassword" class="form-label fw-medium small text-dark">
                            Xác nhận mật khẩu
                        </label>
                        <input asp-for="Input.ConfirmPassword" class="form-control form-control-lg border-light-subtle rounded-3 fs-6" placeholder="Xác nhận lại mật khẩu mới" />
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small mt-1 d-block"></span>
                    </div>
                    
                    <button type="submit" class="btn btn-dark w-100 btn-lg rounded-3 fs-6">
                        Lưu mật khẩu mới
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
