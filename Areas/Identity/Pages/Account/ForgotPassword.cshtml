@page
@model ELearningWebsite.Areas.Identity.Pages.Account.ForgotPasswordModel
@{
    ViewData["Title"] = "Quên mật khẩu";
}

<div class="container py-5 mt-4">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="bg-white p-4 p-md-5 rounded-4 border" style="box-shadow: 0 4px 24px rgba(0,0,0,0.04);">
                <div class="text-center mb-4">
                    <div class="d-inline-flex align-items-center justify-content-center bg-light rounded-circle mb-3" style="width: 64px; height: 64px;">
                        <i class="fas fa-key text-secondary fs-4"></i>
                    </div>
                    <h3 class="fw-bold mb-2" style="font-family: inherit;">Quên mật khẩu?</h3>
                    <p class="text-muted small">
                        Đừng lo lắng, hãy nhập email của bạn dưới đây và chúng tôi sẽ gửi cho bạn một liên kết để lấy lại quyền truy cập.
                    </p>
                </div>
                
                <form id="forgot-password-form" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>
                    
                    <div class="mb-4">
                        <label asp-for="Input.Email" class="form-label fw-medium small text-dark">
                            Địa chỉ email
                        </label>
                        <input asp-for="Input.Email" class="form-control form-control-lg border-light-subtle rounded-3 fs-6" placeholder="name@example.com" />
                        <span asp-validation-for="Input.Email" class="text-danger small mt-1 d-block"></span>
                    </div>
                    
                    <button type="submit" class="btn btn-dark w-100 btn-lg rounded-3 fs-6 mb-3">
                        Gửi liên kết khôi phục
                    </button>
                    
                    <div class="text-center mt-4">
                        <a asp-page="./Login" class="text-decoration-none text-muted small fw-medium text-hover-dark">
                            <i class="fas fa-arrow-left me-1" style="font-size: 0.8rem;"></i>
                            Trở lại trang đăng nhập
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
