@page
@{
    ViewData["Title"] = "Xác nhận quên mật khẩu";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-success text-white text-center">
                    <h4 class="mb-0">
                        <i class="fas fa-check-circle me-2"></i>
                        Email đã được gửi
                    </h4>
                </div>
                <div class="card-body text-center">
                    <div class="mb-4">
                        <i class="fas fa-envelope-open-text fa-4x text-success"></i>
                    </div>
                    
                    <h5 class="mb-3">Kiăm tra email của bạn</h5>
                    
                    <p class="text-muted mb-4">
                        Chúng tôi đã gửi liên kết đặt lại mật khẩu đến email của bạn. 
                        Vui lòng kiăm tra hộp thư và làm theo hương dẫn.
                    </p>
                    
                    <div class="alert alert-info">
                        <i class="fas fa-info-circle me-2"></i>
                        <strong>Lưu ý:</strong> Nếu không thấy email, vui lòng kiăm tra thư mục spam/junk.
                    </div>
                    
                    <div class="d-grid gap-2">
                        <a asp-page="./Login" class="btn btn-primary">
                            <i class="fas fa-arrow-left me-1"></i>
                            Quay lại đăng nhập
                        </a>
                        <a href="/" class="btn btn-outline-secondary">
                            <i class="fas fa-home me-1"></i>
                            Về trang chủ
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
