<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LMS VJU</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- AOS Animation -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <!-- Custom CSS -->
    <link href="~/css/site.css" rel="stylesheet">

</head>
<body>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg fixed-top">
        <div class="container">
            <a class="navbar-brand" href="@Url.Action("Index", "Home")">
                <i class="fas fa-graduation-cap me-2"></i>LMS VJU
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("Index", "Home")">
                            <i class="fas fa-home me-1"></i>Home
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("Courses", "Home")">
                            <i class="fas fa-book me-1"></i>Courses
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("About", "Home")">
                            <i class="fas fa-info-circle me-1"></i>About
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("Contact", "Home")">
                            <i class="fas fa-envelope me-1"></i>Contact
                        </a>
                    </li>
                </ul>

                <partial name="_LoginPartial" />
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main style="margin-top: 80px;">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="footer-shell">
                <div class="row g-4 g-lg-5 align-items-start">
                    <div class="col-lg-5">
                        <a class="footer-brand" href="@Url.Action("Index", "Home")">
                            <span class="footer-brand-icon"><i class="fas fa-graduation-cap"></i></span>
                            <span>LMS VJU</span>
                        </a>
                        <p class="footer-desc mb-3">
                            Nền tảng học tập trực tuyến tập trung kỹ năng thực chiến, giúp bạn xây lộ trình rõ ràng từ cơ bản đến nâng cao.
                        </p>
                        <div class="footer-badges mb-3">
                            <span><i class="fas fa-check-circle"></i> 50+ khóa học</span>
                            <span><i class="fas fa-users"></i> 5.000+ học viên</span>
                            <span><i class="fas fa-certificate"></i> Chứng chỉ hoàn thành</span>
                        </div>
                        <div class="footer-social">
                            <a href="#" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
                            <a href="#" aria-label="Twitter"><i class="fab fa-twitter"></i></a>
                            <a href="#" aria-label="LinkedIn"><i class="fab fa-linkedin-in"></i></a>
                            <a href="#" aria-label="YouTube"><i class="fab fa-youtube"></i></a>
                        </div>
                    </div>

                    <div class="col-lg-3 col-md-6">
                        <h5 class="footer-title">Liên kết nhanh</h5>
                        <ul class="footer-links list-unstyled mb-0">
                            <li><a href="@Url.Action("Courses", "Home")">Khóa học</a></li>
                            <li><a href="@Url.Action("About", "Home")">Giới thiệu</a></li>
                            <li><a href="@Url.Action("Contact", "Home")">Liên hệ</a></li>
                            <li><a href="#">FAQ</a></li>
                            <li><a href="#">Terms of Service</a></li>
                            <li><a href="#">Privacy Policy</a></li>
                        </ul>
                    </div>

                    <div class="col-lg-4 col-md-6">
                        <h5 class="footer-title">Thông tin liên hệ</h5>
                        <div class="footer-contact-cards">
                            <a href="#" class="footer-contact-card text-decoration-none">
                                <i class="fas fa-map-marker-alt"></i>
                                <span>144 Xuân Thủy, Cầu Giấy, Hà Nội</span>
                            </a>
                            <a href="tel:+84365218839" class="footer-contact-card text-decoration-none">
                                <i class="fas fa-phone"></i>
                                <span>+84 36 521 8839</span>
                            </a>
                            <a href="mailto:info@lms-vju.com" class="footer-contact-card text-decoration-none">
                                <i class="fas fa-envelope"></i>
                                <span>info@lms-vju.com</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="footer-divider"></div>
            <div class="footer-bottom row align-items-center g-3">
                <div class="col-md-6">
                    <p class="mb-0">&copy; @DateTime.Now.Year LMS VJU</p>
                </div>
                <div class="col-md-6 text-md-end">
                    <span class="footer-note">Made for practical learning</span>
                </div>
            </div>
        </div>
    </footer>

    @if (User.Identity?.IsAuthenticated ?? false)
    {
        <div id="ai-chatbot-root" class="ai-chatbot-root">
            <button id="ai-chatbot-toggle" class="ai-chatbot-toggle" type="button" aria-label="Mở chatbot AI">
                <i class="fas fa-robot"></i>
                <span>AI Assistant</span>
            </button>

            <div id="ai-chatbot-panel" class="ai-chatbot-panel">
                <div class="ai-chatbot-header">
                    <div>
                        <strong>Trợ lý học tập AI</strong>
                        <div class="small text-muted">Hỏi về khóa học, bài học, lộ trình</div>
                    </div>
                    <div class="d-flex gap-2">
                        <button id="ai-chatbot-clear" class="btn btn-sm btn-outline-secondary" type="button">Xóa</button>
                        <button id="ai-chatbot-close" class="btn btn-sm btn-outline-secondary" type="button">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                </div>

                <div id="ai-chatbot-messages" class="ai-chatbot-messages"></div>

                <div id="ai-chatbot-form" class="ai-chatbot-form" role="form" aria-label="Chatbot form">
                    <div class="ai-chatbot-input-row">
                        <input id="ai-chatbot-input" type="text" class="form-control" maxlength="800"
                               placeholder="Nhập câu hỏi của bạn..." autocomplete="off" />
                        <label for="ai-chatbot-image" class="btn btn-outline-secondary" title="Tải ảnh">
                            <i class="fas fa-image"></i>
                        </label>
                        <input id="ai-chatbot-image" type="file" accept="image/png,image/jpeg,image/webp,image/gif" class="d-none" />
                        <button id="ai-chatbot-send" class="btn btn-primary" type="button">
                            <i class="fas fa-paper-plane"></i>
                        </button>
                    </div>
                    <div id="ai-chatbot-image-preview" class="ai-chatbot-image-preview d-none" aria-live="polite">
                        <img id="ai-chatbot-image-preview-img" alt="Ảnh đã chọn" />
                        <span id="ai-chatbot-image-preview-name"></span>
                        <button id="ai-chatbot-image-remove" type="button" class="btn btn-sm btn-outline-secondary">Bỏ ảnh</button>
                    </div>
                    <div id="ai-chatbot-image-name" class="ai-chatbot-image-name"></div>
                </div>
            </div>
        </div>
    }

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        // Initialize AOS
        AOS.init({
            duration: 800,
            easing: 'ease-in-out',
            once: true
        });

        // Smooth scrolling
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                document.querySelector(this.getAttribute('href')).scrollIntoView({
                    behavior: 'smooth'
                });
            });
        });

        // Website initialization
        console.log('LMS VJU Website loaded successfully!');
    </script>

    @if (User.Identity?.IsAuthenticated ?? false)
    {
        <script src="~/js/chatbot.js"></script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
