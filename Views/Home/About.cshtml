@{
    ViewData["Title"] = "Giới thiệu";
}

<div class="container py-5 mt-4">
    <div class="row mb-5">
        <div class="col-12 text-center" data-aos="fade-up">
            <h1 class="display-4 fw-bold mb-3" style="letter-spacing: -1px;">Về chúng tôi</h1>
            <p class="lead text-muted" style="font-size: 1.15rem;">Nền tảng học tập công nghệ thông tin chuyên nghiệp</p>
        </div>
    </div>

    <div class="row mb-5 align-items-center g-5">
        <div class="col-lg-6 mb-4" data-aos="fade-right">
            <span class="badge bg-light text-dark fw-medium border mb-3 py-2 px-3 rounded-pill">Câu chuyện của chúng tôi</span>
            <h2 class="h3 fw-bold mb-4" style="letter-spacing: -0.5px;">Hành trình bắt đầu tđ sự đđm mê</h2>
            <p class="text-secondary mb-4" style="font-size: 1.05rem; line-height: 1.6;">
                Được thành lập vđi sứ mệnh đem đđn nhđng khóa học lập trình chất lượng cao, 
                chúng tôi đã trở thành một trong nhđng nền tảng học trực tuyđn uy tín nhất trong lĩnh vực CNTT.
            </p>
            <p class="text-secondary mb-4" style="font-size: 1.05rem; line-height: 1.6;">
                Vđi đđi ngũ giảng viên giàu kinh nghiệm và chđđng trình học đđợc thiđt kđ khoa học, 
                chúng tôi cam kđt mang đđn cho học viên nhđng kiđn thđc thực tđ và kđ năng cần thiđt 
                đđ thành công trong ngành công nghệ thông tin.
            </p>
        </div>
        <div class="col-lg-6 mb-4" data-aos="fade-left">
            <div class="position-relative">
                <img src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?q=80&w=1000&auto=format&fit=crop" 
                     alt="About Us" class="img-fluid rounded-4 object-fit-cover"
                     style="height: 400px; width: 100%; box-shadow: 0 12px 32px rgba(0,0,0,0.06);">
            </div>
        </div>
    </div>

    <div class="row mb-5 g-4">
        <div class="col-lg-4" data-aos="fade-up" data-aos-delay="100">
            <div class="card h-100 border border-light-subtle rounded-4 bg-white p-2 category-card">
                <div class="card-body p-4 text-center">
                    <div class="d-inline-flex align-items-center justify-content-center bg-light rounded-circle mb-4" style="width: 64px; height: 64px;">
                        <i class="fas fa-bullseye text-dark fs-4"></i>
                    </div>
                    <h5 class="card-title fw-bold mb-3">Sứ mệnh</h5>
                    <p class="card-text text-muted" style="line-height: 1.6;">
                        Đào tạo nhđng lập trình viên tài năng, có khả năng thích đng vđi 
                        công nghệ mđi và đáp đng nhu cầu của thị trđờng lao động.
                    </p>
                </div>
            </div>
        </div>
        <div class="col-lg-4" data-aos="fade-up" data-aos-delay="200">
            <div class="card h-100 border border-light-subtle rounded-4 bg-white p-2 category-card">
                <div class="card-body p-4 text-center">
                    <div class="d-inline-flex align-items-center justify-content-center bg-light rounded-circle mb-4" style="width: 64px; height: 64px;">
                        <i class="fas fa-eye text-dark fs-4"></i>
                    </div>
                    <h5 class="card-title fw-bold mb-3">Tầm nhìn</h5>
                    <p class="card-text text-muted" style="line-height: 1.6;">
                        Trở thành nền tảng giáo dục CNTT hàng đầu khu vực, 
                        góp phần phát triển nquđn nhân lực công nghệ chất lượng cao.
                    </p>
                </div>
            </div>
        </div>
        <div class="col-lg-4" data-aos="fade-up" data-aos-delay="300">
            <div class="card h-100 border border-light-subtle rounded-4 bg-white p-2 category-card">
                <div class="card-body p-4 text-center">
                    <div class="d-inline-flex align-items-center justify-content-center bg-light rounded-circle mb-4" style="width: 64px; height: 64px;">
                        <i class="fas fa-heart text-dark fs-4"></i>
                    </div>
                    <h5 class="card-title fw-bold mb-3">Giá trđ cốt lõi</h5>
                    <p class="card-text text-muted" style="line-height: 1.6;">
                        Chất lượng, sáng tạo, và cam kđt mang đđn trải nghiệm học tập 
                        tđt nhất cho mọi học viên.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12 text-center" data-aos="zoom-in">
            <div class="bg-dark text-white rounded-5 p-5 mx-lg-4" style="background-image: linear-gradient(135deg, #111827 0%, #374151 100%);">
                <h3 class="mb-3 fw-bold" style="letter-spacing: -0.5px;">Sẵn sàng bđt đău hành trình học tập?</h3>
                <p class="mb-4 text-light" style="opacity: 0.9;">Tham gia cùng hàng nghđn học viên đã thành công vđi chúng tôi</p>
                <a href="@Url.Action("Courses", "Home")" class="btn btn-light btn-lg px-4 rounded-3 fw-medium text-dark">
                    Khám phá khóa học
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    .border-light-subtle {
        border-color: rgba(0,0,0,0.08) !important;
    }
    .category-card {
        transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
    }
    .category-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 24px rgba(0, 0, 0, 0.04);
        border-color: rgba(0,0,0,0.12) !important;
    }
</style>
