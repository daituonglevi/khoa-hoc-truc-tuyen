@{
    ViewData["Title"] = "Giới thiệu";
}

<div class="container py-5 mt-4">
    <div class="row mb-5">
        <div class="col-12 text-center" data-aos="fade-up">
            <h1 class="display-4 fw-bold mb-3" style="letter-spacing: -1px;">About Us</h1>
            <p class="lead text-muted" style="font-size: 1.15rem;"></p>
        </div>
    </div>

    <div class="row mb-5 align-items-center g-5">
        <div class="col-lg-6 mb-4" data-aos="fade-right">
            <span class="badge bg-light text-dark fw-medium border mb-3 py-2 px-3 rounded-pill">Bệ phóng tương lai</span>
            <h2 class="h3 fw-bold mb-4" style="letter-spacing: -0.5px;">Hành trình bắt đầu từ những điều nhỏ bé</h2>
            <p class="text-secondary mb-4" style="font-size: 1.05rem; line-height: 1.6;">
                Được thành lập với sứ mệnh mang đến những khóa học trực tuyến chất lượng cao, chúng tôi đã trở thành nền tảng giáo dục uy tín, nơi học viên có thể tiếp cận không chỉ các chương trình về công nghệ thông tin mà còn nhiều lĩnh vực khác như kinh doanh, thiết kế, ngôn ngữ và kỹ năng mềm. Với đội ngũ giảng viên giàu kinh nghiệm cùng lộ trình học tập khoa học, chúng tôi cam kết đem lại kiến thức thực tiễn và kỹ năng cần thiết để học viên tự tin chinh phục sự nghiệp trong mọi ngành nghề.
            </p>
            <p class="text-secondary mb-4" style="font-size: 1.05rem; line-height: 1.6;">
                Từ những khóa học cơ bản đến các chương trình chuyên sâu, chúng tôi không ngừng cập nhật nội dung để đáp ứng nhu cầu học tập đa dạng của cộng đồng. Chúng tôi tin rằng việc học là một hành trình liên tục, và chúng tôi luôn sẵn sàng đồng hành cùng bạn trên con đường phát triển bản thân và sự nghiệp.
            </p>
        </div>
        <div class="col-lg-6 mb-4" data-aos="fade-left">
            <div class="position-relative">
                 <img src="/images/courses/Screenshot 2026-03-16 085001 ưqw.png" 
                     alt="About Us" class="img-fluid rounded-4 object-fit-cover"
                     style="height: 400px; width: 100%; box-shadow: 0 12px 32px rgba(0,0,0,0.06);">
            </div>
        </div>
    </div>

    <div class="row mb-5 g-4">
        <div class="col-lg-4" data-aos="fade-up" data-aos-delay="100">
            <div class="card h-100 border border-light-subtle rounded-4 bg-white p-2 category-card">
                <div class="card-body p-4 text-center">
                    <div class="d-inline-flex align-items-center justify-content-center bg-light rounded-circle mb-4" style="width: 64px; height: 64px;">
                        <i class="fas fa-bullseye text-dark fs-4"></i>
                    </div>
                    <h5 class="card-title fw-bold mb-3">Sứ mệnh</h5>
                    <p class="card-text text-muted" style="line-height: 1.6;">
                        Cung cấp các khóa học trực tuyến chất lượng cao, giúp học viên phát triển kỹ năng và kiến thức cần thiết để thành công trong sự nghiệp và cuộc sống.
                    </p>
                </div>
            </div>
        </div>
        <div class="col-lg-4" data-aos="fade-up" data-aos-delay="200">
            <div class="card h-100 border border-light-subtle rounded-4 bg-white p-2 category-card">
                <div class="card-body p-4 text-center">
                    <div class="d-inline-flex align-items-center justify-content-center bg-light rounded-circle mb-4" style="width: 64px; height: 64px;">
                        <i class="fas fa-eye text-dark fs-4"></i>
                    </div>
                    <h5 class="card-title fw-bold mb-3">Tầm nhìn</h5>
                    <p class="card-text text-muted" style="line-height: 1.6;">
                        Trở thành nền tảng giáo dục trực tuyến hàng đầu, được tin cậy bởi hàng triệu học viên trên toàn thế giới, góp phần nâng cao chất lượng giáo dục và phát triển nguồn nhân lực toàn cầu.
                    </p>
                </div>
            </div>
        </div>
        <div class="col-lg-4" data-aos="fade-up" data-aos-delay="300">
            <div class="card h-100 border border-light-subtle rounded-4 bg-white p-2 category-card">
                <div class="card-body p-4 text-center">
                    <div class="d-inline-flex align-items-center justify-content-center bg-light rounded-circle mb-4" style="width: 64px; height: 64px;">
                        <i class="fas fa-heart text-dark fs-4"></i>
                    </div>
                    <h5 class="card-title fw-bold mb-3">Giá trđ cốt lõi</h5>
                    <p class="card-text text-muted" style="line-height: 1.6;">
                        Chất lượng, đổi mới, và sự hài lòng của học viên là những giá trị cốt lõi mà chúng tôi luôn hướng đến trong mọi hoạt động và quyết định.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12 text-center" data-aos="zoom-in">
            <div class="bg-dark text-white rounded-5 p-5 mx-lg-4" style="background-image: linear-gradient(135deg, #111827 0%, #374151 100%);">
                <h3 class="mb-3 fw-bold" style="letter-spacing: -0.5px;">Bạn đã sẵn sàng để bắt đầu hành trình học tập?</h3>
                <p class="mb-4 text-light" style="opacity: 0.9;">Tham gia cùng hàng nghìn học viên đã thành công với chúng tôi</p>
                <a href="@Url.Action("Courses", "Home")" class="btn btn-light btn-lg px-4 rounded-3 fw-medium text-dark">
                    Khám phá khóa học
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    .border-light-subtle {
        border-color: rgba(0,0,0,0.08) !important;
    }
    .category-card {
        transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
    }
    .category-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 24px rgba(0, 0, 0, 0.04);
        border-color: rgba(0,0,0,0.12) !important;
    }
</style>
