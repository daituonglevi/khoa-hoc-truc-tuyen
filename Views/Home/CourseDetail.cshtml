@model CourseDetailViewModel
@{
    ViewData["Title"] = Model.Course.Title;
}

<!-- Hero Section -->
<div class="course-detail-hero position-relative" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); min-height: 320px; overflow: hidden;">
    <div class="position-absolute top-0 start-0 w-100 h-100" 
         style="background-image: url('@Model.Course.Thumbnail'); background-size: cover; background-position: center; opacity: 0.2; filter: blur(8px);"></div>
    
    <div class="container position-relative py-5">
        <!-- Breadcrumb -->
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb breadcrumb-white mb-0">
                <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")" class="text-white-50 text-decoration-none">Trang chủ</a></li>
                <li class="breadcrumb-item"><a href="@Url.Action("Courses", "Home")" class="text-white-50 text-decoration-none">Khóa học</a></li>
                <li class="breadcrumb-item"><a href="@Url.Action("Courses", "Home", new { categoryId = Model.Course.CategoryId })" class="text-white-50 text-decoration-none">@Model.Course.Category.Name</a></li>
                <li class="breadcrumb-item active text-white" aria-current="page">@Model.Course.Title</li>
            </ol>
        </nav>

        <div class="row align-items-end gap-4">
            <!-- Hero Thumbnail -->
            <div class="col-lg-3">
                <img src="@Model.Course.Thumbnail" alt="@Model.Course.Title"
                     class="img-fluid rounded-4 shadow-lg border-3 border-white" style="object-fit: cover; height: 220px; width: 100%;" data-aos="zoom-in">
            </div>

            <!-- Hero Content -->
            <div class="col-lg-auto flex-grow-1 text-white" data-aos="fade-up">
                <div class="mb-3">
                    <span class="badge bg-white bg-opacity-20 backdrop-blur px-4 py-2 rounded-pill fw-medium text-white position-relative" style="border: 1px solid rgba(255,255,255,0.3);">
                        <i class="fas fa-tag me-1"></i>@Model.Course.Category.Name
                    </span>
                </div>
                
                <h1 class="display-4 fw-bold mb-3 text-white" style="letter-spacing: -0.5px; line-height: 1.3; word-wrap: break-word; overflow-wrap: break-word;">@Model.Course.Title</h1>
                
                <div class="d-flex flex-wrap gap-4 mb-0">
                    <!-- Rating -->
                    <div class="d-flex align-items-center gap-2">
                        <div class="d-flex gap-1">
                            @for (int i = 1; i <= 5; i++)
                            {
                                @if (i <= Model.Rating)
                                {
                                    <i class="fas fa-star" style="color: #ffc107; font-size: 1rem;"></i>
                                }
                                else
                                {
                                    <i class="far fa-star" style="color: rgba(255,255,255,0.5); font-size: 1rem;"></i>
                                }
                            }
                        </div>
                        <span class="fw-medium">@Model.Rating.ToString("F1")</span>
                        <span class="text-white-50">(@Model.ReviewCount)</span>
                    </div>

                    <!-- Students -->
                    <div class="d-flex align-items-center gap-2">
                        <i class="fas fa-users"></i>
                        <span class="fw-medium">@Model.Course.Enrollments.Count() học viên</span>
                    </div>

                    <!-- Updated -->
                    <div class="d-flex align-items-center gap-2">
                        <i class="fas fa-clock"></i>
                        <span class="fw-medium">Cập nhật @(Model.Course.UpdatedAt?.ToString("dd/MM/yyyy") ?? Model.Course.CreatedAt.ToString("dd/MM/yyyy"))</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container py-5">

    <!-- Main Grid -->
    <div class="row g-4">
        <!-- Left Column: Video + Description + Content + Comments -->
        <div class="col-lg-8">
            <!-- Video Section -->
            <div class="mb-5" data-aos="fade-up">
                <div class="position-relative rounded-4 overflow-hidden shadow-lg bg-dark" style="background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%); min-height: 450px;">
                    <div class="ratio ratio-16x9">
                        <partial name="_VideoEmbed" model='new ELearningWebsite.Models.ViewModels.VideoEmbedViewModel
                        {
                            Url = Model.Course.PreviewVideo,
                            Title = Model.Course.Title,
                            IframeClass = "w-100 h-100 rounded-0",
                            VideoClass = "w-100 rounded-0"
                        }' />
                    </div>
                </div>
            </div>

            <!-- Quick Stats Grid -->
            <div class="row g-3 mb-5" data-aos="fade-up" data-aos-delay="100">
                <div class="col-12 col-sm-6 col-lg-3">
                    <div class="card border-0 rounded-3 shadow-sm text-center p-4 h-100 position-relative overflow-hidden" style="background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%); min-height: 160px;">
                        @* <div class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center opacity-10" style="font-size: 4rem;">
                            <i class="fas fa-book"></i>
                        </div> *@
                        <div class="position-relative z-2">
                            <div class="fs-5 fw-bold text-dark mb-2">@Model.Course.Chapters.Count()</div>
                            <small class="text-muted fw-medium" style="font-size: 0.9rem; line-height: 1.4; display: block; text-transform: uppercase;">Chương</small>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-sm-6 col-lg-3">
                    <div class="card border-0 rounded-3 shadow-sm text-center p-4 h-100 position-relative overflow-hidden" style="background: linear-gradient(135deg, rgba(76, 175, 80, 0.1) 0%, rgba(56, 142, 60, 0.1) 100%); min-height: 160px;">
                            @* <div class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center opacity-10" style="font-size: 4rem;">
                                <i class="fas fa-play"></i>
                            </div> *@
                        <div class="position-relative z-2">
                            <div class="fs-5 fw-bold text-dark mb-2">@Model.Course.Chapters.Sum(c => c.Lessons.Count())</div>
                            <small class="text-muted fw-medium" style="font-size: 0.9rem; line-height: 1.4; display: block; text-transform: uppercase;">Bài học</small>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-sm-6 col-lg-3">
                    <div class="card border-0 rounded-3 shadow-sm text-center p-4 h-100 position-relative overflow-hidden" style="background: linear-gradient(135deg, rgba(255, 152, 0, 0.1) 0%, rgba(255, 111, 0, 0.1) 100%); min-height: 160px;">
                        @* <div class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center opacity-10" style="font-size: 4rem;">
                            <i class="fas fa-clock"></i>
                        </div> *@
                        <div class="position-relative z-2">
                            <div class="fs-5 fw-bold text-dark mb-2">@(Model.Course.Duration?.ToString(@"hh\:mm") ?? "N/A")</div>
                            <small class="text-muted fw-medium" style="font-size: 0.9rem; line-height: 1.4; display: block; text-transform: uppercase;">Thời lượng</small>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-sm-6 col-lg-3">
                    <div class="card border-0 rounded-3 shadow-sm text-center p-4 h-100 position-relative overflow-hidden" style="background: linear-gradient(135deg, rgba(233, 30, 99, 0.1) 0%, rgba(156, 39, 176, 0.1) 100%); min-height: 160px;">
                        @* <div class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center opacity-10" style="font-size: 4rem;">
                            <i class="fas fa-certificate"></i>
                        </div> *@
                        <div class="position-relative z-2">
                            <div class="fs-5 fw-bold text-dark mb-2">Có</div>
                            <small class="text-muted fw-medium" style="font-size: 0.9rem; line-height: 1.4; display: block; text-transform: uppercase;">Chứng chỉ</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Description -->
            <div class="mb-5" data-aos="fade-up" data-aos-delay="200">
                <h3 class="fw-bold mb-3 h4">📖 Mô tả khóa học</h3>
                <div class="card border-0 rounded-4 shadow-sm p-4" style="background: linear-gradient(135deg, rgba(255,255,255,1) 0%, rgba(249,250,252,1) 100%);">
                    <div class="course-description text-secondary lh-lg">
                        @Html.Raw(Model.Course.Description)
                    </div>
                </div>
            </div>

            <!-- Course Content (Curriculum) -->
            <div class="mb-5" data-aos="fade-up" data-aos-delay="300">
                <h3 class="fw-bold mb-3 h4">📚 Nội dung khóa học</h3>
                <div class="card border-0 rounded-4 shadow-sm overflow-hidden">
                    @if (Model.Course.Chapters.Any())
                    {
                        <div class="accordion" id="courseContent">
                            @foreach (var chapter in Model.Course.Chapters.OrderBy(c => c.Id))
                            {
                                <div class="accordion-item border-0 border-bottom border-light">
                                    <h2 class="accordion-header" id="heading@chapter.Id">
                                        <button class="accordion-button @(Model.Course.Chapters.First() != chapter ? "collapsed" : "") fw-bold"
                                                type="button" data-bs-toggle="collapse"
                                                data-bs-target="#collapse@chapter.Id"
                                                style="background-color: @(Model.Course.Chapters.First() == chapter ? "rgba(102, 126, 234, 0.05)" : "transparent");">
                                            <i class="fas fa-folder-open me-2" style="color: #667eea;"></i>
                                            <span>@chapter.Name</span>
                                            <span class="text-muted ms-auto me-3">@(chapter.Lessons?.Count() ?? 0) bài học</span>
                                        </button>
                                    </h2>
                                    <div id="collapse@chapter.Id"
                                         class="accordion-collapse collapse @(Model.Course.Chapters.First() == chapter ? "show" : "")"
                                         data-bs-parent="#courseContent">
                                        <div class="accordion-body p-4" style="background: rgba(249, 250, 252, 1);">
                                            @if (chapter.Description != null)
                                            {
                                                <p class="text-muted mb-3 border-bottom pb-3">@chapter.Description</p>
                                            }

                                            @if (chapter.Lessons != null && chapter.Lessons.Any())
                                            {
                                                <div class="lesson-list">
                                                    @foreach (var lesson in chapter.Lessons.OrderBy(l => l.OrderIndex))
                                                    {
                                                        <div class="d-flex align-items-center justify-content-between p-3 rounded-3 mb-2" style="background: white; border-left: 3px solid #667eea; transition: all 0.3s;">
                                                            <div class="d-flex align-items-center flex-grow-1">
                                                                <i class="fas fa-@(lesson.Type == "Video" ? "play-circle" : lesson.Type == "Quiz" ? "question-circle" : "file-alt") fs-5 me-3" style="color: #667eea;"></i>
                                                                <div>
                                                                    <div class="fw-medium text-dark mb-1">@lesson.Title</div>
                                                                    <small class="text-muted">Loại: @lesson.Type</small>
                                                                </div>
                                                            </div>
                                                            <div class="d-flex align-items-center gap-2">
                                                                <span class="badge bg-@(lesson.Status == "Active" ? "success" : "secondary") rounded-pill">@lesson.Status</span>
                                                                <a href="/Learning/Lesson/@lesson.Id" class="btn btn-sm btn-outline-primary rounded-3">
                                                                    <i class="fas fa-arrow-right"></i>
                                                                </a>
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="text-center py-4">
                                                    <i class="fas fa-book-open fa-2x text-muted mb-2"></i>
                                                    <p class="text-muted">Nội dung bài học đang được cập nhật</p>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                            <h5 class="text-muted fw-bold">Nội dung đang được cập nhật</h5>
                            <p class="text-muted">Khóa học này đang trong quá trình xây dựng nội dung.</p>
                        </div>
                    }
                </div>
            </div>

            <!-- Comments Section -->
            <div class="mb-5" data-aos="fade-up" data-aos-delay="400">
                <h3 class="fw-bold mb-3 h4">💬 Thảo luận và bình luận</h3>
                <div class="card border-0 rounded-4 shadow-sm overflow-hidden">
                    <div class="p-4">
                        @if (User.Identity!.IsAuthenticated)
                        {
                            <div class="mb-4 pb-4 border-bottom">
                                <form id="commentForm">
                                    <div class="mb-3">
                                        <label class="form-label fw-bold mb-2">Viết bình luận của bạn</label>
                                        <textarea id="commentContent" class="form-control border-light-subtle rounded-3"
                                                placeholder="Chia sẻ ý kiến của bạn..."
                                                rows="4" maxlength="2000" style="resize: vertical;"></textarea>
                                        <div class="d-flex justify-content-between align-items-center mt-2">
                                            <small class="text-muted"><span id="charCount">0</span>/2000</small>
                                            <button type="submit" class="btn btn-primary rounded-pill px-4 fw-medium" id="submitComment">
                                                <i class="fas fa-paper-plane me-2"></i>Bình luận
                                            </button>
                                        </div>
                                    </div>
                                    @Html.AntiForgeryToken()
                                </form>
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-5 rounded-4" style="background: linear-gradient(135deg, rgba(102, 126, 234, 0.05) 0%, rgba(118, 75, 162, 0.05) 100%);">
                                <i class="fas fa-user-lock fa-2x text-muted mb-3"></i>
                                <h5 class="fw-bold text-dark mb-2">Đăng nhập để tham gia thảo luận</h5>
                                <p class="text-muted mb-3 small">Vui lòng đăng nhập để bình luận và tương tác với cộng đồng</p>
                                <a href="/Identity/Account/Login?returnUrl=@Url.Action("CourseDetail", "Home", new { id = Model.Course.Id })"
                                   class="btn btn-primary rounded-pill px-4">
                                    <i class="fas fa-sign-in-alt me-2"></i>Đăng nhập
                                </a>
                            </div>
                        }

                        <!-- Comments List -->
                        <div id="commentsList" class="mt-4">
                            <div class="text-center py-4" id="commentsLoading">
                                <div class="spinner-border spinner-border-sm text-primary" role="status">
                                    <span class="visually-hidden">Đang tải...</span>
                                </div>
                                <p class="text-muted small mt-2">Đang tải bình luận...</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Sidebar: Purchase + Info -->
        <div class="col-lg-4">
            <div class="position-sticky" style="top: 120px;">
                <!-- Price & Purchase Card -->
                <div class="card border-0 rounded-4 shadow-lg overflow-hidden mb-4" data-aos="fade-left" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                    <div class="card-body p-4 text-white text-center">
                        <img src="@Model.Course.Thumbnail" alt="@Model.Course.Title"
                             class="img-fluid rounded-3 mb-4 shadow" style="object-fit: cover; height: 180px; width: 100%;">

                        <div class="mb-4">
                            @if (Model.Course.Price == 0)
                            {
                                <div class="fs-2 fw-bold mb-1">Miễn phí</div>
                                <small class="text-white-50">Không yêu cầu thanh toán</small>
                            }
                            else
                            {
                                <div class="fs-1 fw-bold mb-1">@Model.Course.Price.ToString("N0") 
                                    <span class="fs-5" style="opacity: 0.8;">đ</span>
                                </div>
                                <small class="text-white-50">Chỉ một lần</small>
                            }
                        </div>

                        @if (User.Identity!.IsAuthenticated)
                        {
                            @if (Model.IsEnrolled)
                            {
                                <a href="@Url.Action("MyCourses", "User")"
                                   class="btn btn-light btn-lg w-100 mb-2 rounded-3 fw-bold" style="color: #667eea;">
                                    <i class="fas fa-play me-2"></i>Tiếp tục học tập
                                </a>
                                <a href="@Url.Action("Dashboard", "User")"
                                   class="btn btn-outline-light w-100 rounded-3 fw-medium">
                                    <i class="fas fa-chart-line me-2"></i>Xem tiến độ
                                </a>
                            }
                            else
                            {
                                @if (Model.Course.Price == 0)
                                {
                                    <button type="button" class="btn btn-light btn-lg w-100 rounded-3 fw-bold"
                                            onclick="enrollCourse(@Model.Course.Id)" style="color: #667eea;">
                                        <i class="fas fa-check-circle me-2"></i>Đăng ký miễn phí
                                    </button>
                                }
                                else
                                {
                                    <a href="@Url.Action("Checkout", "Enrollment", new { id = Model.Course.Id })"
                                       class="btn btn-light btn-lg w-100 rounded-3 fw-bold mb-2" style="color: #667eea;">
                                        <i class="fas fa-shopping-cart me-2"></i>Đăng ký ngay
                                    </a>
                                    <small class="text-white-50 d-block">
                                        <i class="fas fa-lock-open me-1"></i>Thanh toán an toàn 100%
                                    </small>
                                }
                            }
                        }
                        else
                        {
                            <a href="/Identity/Account/Login?returnUrl=@Url.Action("CourseDetail", "Home", new { id = Model.Course.Id })"
                               class="btn btn-light btn-lg w-100 rounded-3 fw-bold mb-2" style="color: #667eea;">
                                <i class="fas fa-sign-in-alt me-2"></i>Đăng nhập để học
                            </a>
                            <p class="mb-0 small text-white-50 text-center">
                                Hoặc <a href="/Identity/Account/Register" class="text-white text-decoration-none fw-bold border-bottom">tạo tài khoản mới</a>
                            </p>
                        }

                        <div class="mt-4 pt-3 border-top border-white border-opacity-20">
                            <small class="text-white-50 d-block">
                                <i class="fas fa-undo me-1"></i>Hoàn tiền trong 30 ngày nếu không hài lòng
                            </small>
                        </div>
                    </div>
                </div>

                <!-- Key Features -->
                <div class="card border-0 rounded-4 shadow-sm mb-4" data-aos="fade-left" data-aos-delay="100">
                    <div class="card-body p-4">
                        <h6 class="fw-bold mb-3 text-dark">✨ Bao gồm</h6>
                        <ul class="list-unstyled">
                            <li class="mb-2 d-flex gap-2">
                                <i class="fas fa-check text-success mt-1"></i>
                                <span class="text-muted">Truy cập vĩnh viễn</span>
                            </li>
                            <li class="mb-2 d-flex gap-2">
                                <i class="fas fa-check text-success mt-1"></i>
                                <span class="text-muted">Tài liệu học tập đầy đủ</span>
                            </li>
                            <li class="mb-2 d-flex gap-2">
                                <i class="fas fa-check text-success mt-1"></i>
                                <span class="text-muted">Hỗ trợ từ cộng đồng</span>
                            </li>
                            <li class="mb-2 d-flex gap-2">
                                <i class="fas fa-check text-success mt-1"></i>
                                <span class="text-muted">Chứng chỉ hoàn thành</span>
                            </li>
                            <li class="mb-0 d-flex gap-2">
                                <i class="fas fa-check text-success mt-1"></i>
                                <span class="text-muted">Cập nhật nội dung thường xuyên</span>
                            </li>
                        </ul>
                    </div>
                </div>

                <!-- Related Courses -->
                @if (Model.RelatedCourses.Any())
                {
                    <div class="card border-0 rounded-4 shadow-sm" data-aos="fade-left" data-aos-delay="200">
                        <div class="card-body p-4">
                            <h6 class="fw-bold mb-3 text-dark">🎓 Khóa học liên quan</h6>
                            @foreach (var relatedCourse in Model.RelatedCourses.Where(c => c.Id != Model.Course.Id).Take(3))
                            {
                                <a href="@Url.Action("CourseDetail", "Home", new { id = relatedCourse.Id })" 
                                   class="d-flex gap-3 mb-3 text-decoration-none related-course-item" style="transition: all 0.3s;">
                                    <img src="@relatedCourse.Thumbnail" alt="@relatedCourse.Title"
                                         class="rounded-3 object-fit-cover flex-shrink-0"
                                         style="width: 60px; height: 45px;">
                                    <div class="flex-grow-1 min-width-0">
                                        <div class="fw-bold text-dark mb-1" style="font-size: 0.9rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                            @relatedCourse.Title
                                        </div>
                                        <div class="d-flex justify-content-between align-items-center">
                                            <small class="text-muted"><i class="fas fa-users me-1"></i>@relatedCourse.Enrollments.Count()</small>
                                            @if (relatedCourse.Price == 0)
                                            {
                                                <span class="badge bg-success rounded-pill fw-normal" style="font-size: 0.75rem;">Miễn phí</span>
                                            }
                                            else
                                            {
                                                <small class="text-dark fw-bold">@relatedCourse.Price.ToString("N0") đ</small>
                                            }
                                        </div>
                                    </div>
                                </a>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    /* Hero Section */
    .course-detail-hero {
        position: relative;
        overflow: hidden;
    }

    .course-detail-hero .breadcrumb-white {
        --bs-breadcrumb-divider-color: rgba(255, 255, 255, 0.5);
    }

    .course-detail-hero .breadcrumb-white .breadcrumb-item.active {
        color: white;
        font-weight: 500;
    }

    /* Course Description */
    .course-description {
        line-height: 1.8;
        font-size: 1rem;
    }

    .course-description p {
        margin-bottom: 1.25rem;
        color: #495057;
    }

    .course-description h2,
    .course-description h3,
    .course-description h4 {
        color: #212529;
        font-weight: 600;
        margin-top: 1.5rem;
        margin-bottom: 0.75rem;
    }

    .course-description ul,
    .course-description ol {
        margin-bottom: 1.25rem;
        margin-left: 1.5rem;
    }

    .course-description li {
        margin-bottom: 0.5rem;
    }

    /* Stats Grid */
    .position-relative.overflow-hidden {
        transition: all 0.3s ease;
    }

    /* Accordion Styles */
    .accordion-button {
        background-color: transparent;
        color: #212529;
        border: none;
        font-weight: 500;
        padding: 1.25rem 1.5rem;
        transition: all 0.3s;
    }

    .accordion-button:not(.collapsed) {
        background-color: rgba(102, 126, 234, 0.08);
        color: #667eea;
        box-shadow: none;
    }

    .accordion-button:hover {
        background-color: rgba(102, 126, 234, 0.05);
        color: #667eea;
    }

    .accordion-button:focus {
        border-color: #667eea;
        box-shadow: 0 0 0 0.25rem rgba(102, 126, 234, 0.25);
    }

    .accordion-button::after {
        filter: invert(0.8);
    }

    .accordion-button:not(.collapsed)::after {
        filter: invert(0.3);
    }

    .lesson-list .d-flex:hover {
        background: rgb(102, 126, 234) !important;
        background: linear-gradient(135deg, rgba(102, 126, 234, 0.08) 0%, rgba(118, 75, 162, 0.05) 100%) !important;
        transform: translateX(4px);
    }

    /* Sticky Sidebar */
    .position-sticky {
        z-index: 1000;
    }

    /* Comment Styles */
    .comment-item {
        border-bottom: 1px solid rgba(0, 0, 0, 0.05);
        padding: 1.5rem 0;
    }

    .comment-item:last-child {
        border-bottom: none;
    }

    .comment-content {
        background-color: #f8f9fa;
        border-radius: 12px;
        padding: 1.25rem;
        margin-bottom: 0.75rem;
        border: 1px solid rgba(0, 0, 0, 0.03);
    }

    .comment-reply {
        margin-left: 3rem;
        border-left: 3px solid #667eea;
        padding-left: 1.5rem;
        margin-top: 1.25rem;
    }

    .comment-actions {
        font-size: 0.85rem;
        font-weight: 500;
        margin-left: 0.75rem;
    }

    .comment-actions button {
        background: none;
        border: none;
        color: #6b7280;
        padding: 0.35rem 0.65rem;
        cursor: pointer;
        transition: all 0.2s;
        border-radius: 6px;
        font-size: 0.8rem;
    }

    .comment-actions button:hover {
        color: #667eea;
        background-color: rgba(102, 126, 234, 0.1);
    }

    .reply-form {
        margin-top: 0.75rem;
        padding: 1rem;
        background-color: #f8f9fa;
        border-radius: 0.75rem;
        display: none;
        border-left: 3px solid #667eea;
    }

    .comment-form textarea:focus {
        border-color: #667eea;
        box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.15);
    }

    .comment-time {
        font-size: 0.8rem;
        color: #999;
    }

    .no-comments {
        text-align: center;
        padding: 2.5rem;
        color: #999;
    }

    /* Related Courses Hover */
    .related-course-item:hover {
        transform: translateX(4px);
    }

    .related-course-item:hover img {
        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.12) !important;
    }

    /* Responsive Design */
    @@media (max-width: 768px) {
        .course-detail-hero {
            min-height: 280px;
        }

        .course-detail-hero .row {
            gap: 2rem !important;
        }

        .course-detail-hero .col-lg-3,
        .course-detail-hero .col-lg-auto {
            flex: 0 0 100% !important;
            max-width: 100%;
        }

        .position-sticky {
            position: static !important;
            margin-top: 2rem;
        }

        .accordion-button {
            padding: 1rem 1.25rem;
            font-size: 0.95rem;
        }

        .card-body {
            padding: 1rem !important;
        }
    }

    /* Smooth Transitions */
    .card {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .card:hover {
        transform: translateY(-2px);
    }

    /* Text Utilities */
    .text-hover-primary:hover {
        color: #667eea !important;
    }

    .min-width-0 {
        min-width: 0;
    }

    .z-2 {
        position: relative;
        z-index: 2;
    }

    /* Animations */
    @@keyframes slideIn {
        from {
            opacity: 0;
            transform: translateX(-20px);
        }
        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    .lesson-list > div {
        animation: slideIn 0.3s ease-out forwards;
    }

    .lesson-list > div:nth-child(1) { animation-delay: 0s; }
    .lesson-list > div:nth-child(2) { animation-delay: 0.05s; }
    .lesson-list > div:nth-child(3) { animation-delay: 0.1s; }
    .lesson-list > div:nth-child(4) { animation-delay: 0.15s; }
    .lesson-list > div:nth-child(5) { animation-delay: 0.2s; }
</style>

<script>
    function enrollCourse(courseId) {
        if (!courseId) {
            showToast('Lỗi: Không tìm thấy thông tin khóa học!', 'error');
            return;
        }

        // Hiăn thị loading
        const button = event.target;
        const originalText = button.innerHTML;
        button.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Đang xử lý...';
        button.disabled = true;

        // Gọi API đăng ký khóa học
        fetch('@Url.Action("ProcessEnrollment", "Enrollment")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
            },
            body: `courseId=${courseId}`
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                showToast(data.message, 'success');
                if (data.redirectUrl) {
                    setTimeout(() => {
                        window.location.href = data.redirectUrl;
                    }, 1500);
                } else {
                    // Reload page đă cập nhật trạng thái
                    setTimeout(() => {
                        window.location.reload();
                    }, 1500);
                }
            } else {
                showToast(data.message, 'error');
                button.innerHTML = originalText;
                button.disabled = false;
            }
        })
        .catch(error => {
            console.error('Error:', error);
            showToast('Có lỗi xảy ra, vui lòng thử lại!', 'error');
            button.innerHTML = originalText;
            button.disabled = false;
        });
    }

    function showToast(message, type) {
        const toast = document.createElement('div');
        toast.className = `alert alert-${type === 'success' ? 'success' : type === 'info' ? 'info' : 'danger'} position-fixed`;
        toast.style.cssText = 'top: 100px; right: 20px; z-index: 9999; min-width: 300px;';
        toast.innerHTML = `
            <i class="fas fa-${type === 'success' ? 'check-circle' : type === 'info' ? 'info-circle' : 'exclamation-circle'} me-2"></i>
            ${message}
            <button type="button" class="btn-close float-end" onclick="this.parentElement.remove()"></button>
        `;
        document.body.appendChild(toast);

        setTimeout(() => {
            if (toast.parentElement) {
                toast.remove();
            }
        }, 5000);
    }

    // Comment functionality
    const courseId = @Model.Course.Id;
    let currentUser = @(User.Identity!.IsAuthenticated ? "true" : "false");

    document.addEventListener('DOMContentLoaded', function() {
        // Add CSRF token
        if (!document.querySelector('input[name="__RequestVerificationToken"]')) {
            const form = document.createElement('form');
            form.style.display = 'none';
            form.innerHTML = '@Html.AntiForgeryToken()';
            document.body.appendChild(form);
        }

        // Load comments
        if (currentUser) {
            loadComments();
            setupCommentForm();
        }
    });

    function loadComments() {
        fetch(`/Comment/GetComments?courseId=${courseId}`)
            .then(response => response.json())
            .then(data => {
                const loadingDiv = document.getElementById('commentsLoading');
                const commentsList = document.getElementById('commentsList');

                if (loadingDiv) {
                    loadingDiv.style.display = 'none';
                }

                if (data.success) {
                    displayComments(data.comments);
                } else {
                    commentsList.innerHTML = '<div class="alert alert-warning">Không thă tải bình luận</div>';
                }
            })
            .catch(error => {
                console.error('Error loading comments:', error);
                document.getElementById('commentsList').innerHTML =
                    '<div class="alert alert-danger">Có lỗi xảy ra khi tải bình luận</div>';
            });
    }

    function displayComments(comments) {
        const commentsList = document.getElementById('commentsList');

        if (comments.length === 0) {
            commentsList.innerHTML = `
                <div class="no-comments">
                    <i class="fas fa-comments fa-3x mb-3"></i>
                    <h5>Chưa có bình luận nào</h5>
                    <p>Hãy là người đầu tiên bình luận về khóa học này!</p>
                </div>
            `;
            return;
        }

        let html = '';
        comments.forEach(comment => {
            html += renderComment(comment);
        });

        commentsList.innerHTML = html;
    }

    function renderComment(comment, isReply = false) {
        const timeAgo = getTimeAgo(new Date(comment.createdAt));
        const replyClass = isReply ? 'comment-reply' : '';

        let html = `
            <div class="comment-item ${replyClass}" data-comment-id="${comment.id}">
                <div class="d-flex">
                    <div class="flex-grow-1">
                        <div class="comment-content">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h6 class="mb-0">${comment.userName}</h6>
                                <span class="comment-time">${timeAgo}</span>
                            </div>
                            <p class="mb-0">${comment.content}</p>
                        </div>
                        <div class="comment-actions">
                            ${!isReply ? `<button onclick="showReplyForm(${comment.id})">
                                <i class="fas fa-reply me-1"></i>Trả lời
                            </button>` : ''}
                            ${comment.userId && comment.userId === getCurrentUserId() ? `
                                <button onclick="deleteComment(${comment.id})" class="text-danger">
                                    <i class="fas fa-trash me-1"></i>Xóa
                                </button>
                            ` : ''}
                        </div>
                        <div id="replyForm${comment.id}" class="reply-form"></div>
                    </div>
                </div>
        `;

        // Add replies
        if (comment.replies && comment.replies.length > 0) {
            comment.replies.forEach(reply => {
                html += renderComment(reply, true);
            });
        }

        html += '</div>';
        return html;
    }

    function setupCommentForm() {
        const form = document.getElementById('commentForm');
        const textarea = document.getElementById('commentContent');
        const charCount = document.getElementById('charCount');
        const submitBtn = document.getElementById('submitComment');

        // Character counter
        textarea.addEventListener('input', function() {
            const count = this.value.length;
            charCount.textContent = count;

            if (count > 2000) {
                charCount.style.color = '#dc3545';
            } else {
                charCount.style.color = '#6c757d';
            }
        });

        // Form submission
        form.addEventListener('submit', function(e) {
            e.preventDefault();

            const content = textarea.value.trim();
            if (!content) {
                showToast('Vui lòng nhập nội dung bình luận', 'error');
                return;
            }

            if (content.length > 2000) {
                showToast('Nội dung bình luận không được vượt quá 2000 ký tự', 'error');
                return;
            }

            postComment(content);
        });
    }

    function postComment(content, parentCommentId = null) {
        const submitBtn = document.getElementById('submitComment');
        const originalText = submitBtn.innerHTML;

        // Show loading state
        submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Đang đăng...';
        submitBtn.disabled = true;

        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

        fetch('/Comment/PostComment', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': token
            },
            body: JSON.stringify({
                content: content,
                courseId: courseId,
                parentCommentId: parentCommentId
            })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                showToast(data.message, 'success');

                // Clear form
                document.getElementById('commentContent').value = '';
                document.getElementById('charCount').textContent = '0';

                // Reload comments
                loadComments();
            } else {
                showToast(data.message, 'error');
            }
        })
        .catch(error => {
            console.error('Error posting comment:', error);
            showToast('Có lỗi xảy ra khi đăng bình luận', 'error');
        })
        .finally(() => {
            // Restore button state
            submitBtn.innerHTML = originalText;
            submitBtn.disabled = false;
        });
    }

    function showReplyForm(commentId) {
        // Hide all other reply forms
        document.querySelectorAll('.reply-form').forEach(form => {
            form.style.display = 'none';
            form.innerHTML = '';
        });

        const replyFormDiv = document.getElementById(`replyForm${commentId}`);
        replyFormDiv.style.display = 'block';
        replyFormDiv.innerHTML = `
            <div class="d-flex">
                <div class="flex-grow-1">
                    <textarea id="replyContent${commentId}" class="form-control mb-2"
                            placeholder="Viết phản hôi..." rows="2" maxlength="2000"></textarea>
                    <div class="d-flex justify-content-between">
                        <small class="text-muted">
                            <span id="replyCharCount${commentId}">0</span>/2000 ký tự
                        </small>
                        <div>
                            <button type="button" class="btn btn-sm btn-outline-secondary me-2"
                                    onclick="hideReplyForm(${commentId})">Hủy</button>
                            <button type="button" class="btn btn-sm btn-primary"
                                    onclick="submitReply(${commentId})">
                                <i class="fas fa-paper-plane me-1"></i>Trả lời
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        `;

        // Setup character counter for reply
        const replyTextarea = document.getElementById(`replyContent${commentId}`);
        const replyCharCount = document.getElementById(`replyCharCount${commentId}`);

        replyTextarea.addEventListener('input', function() {
            const count = this.value.length;
            replyCharCount.textContent = count;

            if (count > 2000) {
                replyCharCount.style.color = '#dc3545';
            } else {
                replyCharCount.style.color = '#6c757d';
            }
        });

        replyTextarea.focus();
    }

    function hideReplyForm(commentId) {
        const replyFormDiv = document.getElementById(`replyForm${commentId}`);
        replyFormDiv.style.display = 'none';
        replyFormDiv.innerHTML = '';
    }

    function submitReply(commentId) {
        const replyTextarea = document.getElementById(`replyContent${commentId}`);
        const content = replyTextarea.value.trim();

        if (!content) {
            showToast('Vui lòng nhập nội dung phản hôi', 'error');
            return;
        }

        if (content.length > 2000) {
            showToast('Nội dung phản hôi không được vượt quá 2000 ký tự', 'error');
            return;
        }

        postComment(content, commentId);
        hideReplyForm(commentId);
    }

    function deleteComment(commentId) {
        if (!confirm('Bạn có chắc chắn muđn xóa bình luận này?')) {
            return;
        }

        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

        fetch(`/Comment/DeleteComment/${commentId}`, {
            method: 'POST',
            headers: {
                'RequestVerificationToken': token
            }
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                showToast(data.message, 'success');
                loadComments();
            } else {
                showToast(data.message, 'error');
            }
        })
        .catch(error => {
            console.error('Error deleting comment:', error);
            showToast('Có lỗi xảy ra khi xóa bình luận', 'error');
        });
    }

    function getTimeAgo(date) {
        const now = new Date();
        const diffInSeconds = Math.floor((now - date) / 1000);

        if (diffInSeconds < 60) {
            return 'Vừa xong';
        } else if (diffInSeconds < 3600) {
            const minutes = Math.floor(diffInSeconds / 60);
            return `${minutes} phút trước`;
        } else if (diffInSeconds < 86400) {
            const hours = Math.floor(diffInSeconds / 3600);
            return `${hours} giờ trước`;
        } else {
            const days = Math.floor(diffInSeconds / 86400);
            return `${days} ngày trước`;
        }
    }

    function getCurrentUserId() {
        // This is a simplified approach. In a real application, you might want to
        // pass the current user ID from the server or store it in a more secure way
        return null; // Will be implemented when we have proper user context
    }
</script>

