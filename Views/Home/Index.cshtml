@model HomeViewModel
@{
    ViewData["Title"] = "Trang chủ";
}

<!-- Hero Section -->
<section class="py-5 pt-md-5 pb-md-0 bg-white">
    <div class="container py-lg-5">
        <div class="row align-items-center g-5 pb-5">
            <div class="col-lg-6" data-aos="fade-right">
                <span class="badge bg-light text-dark fw-medium border mb-3 py-2 px-3 rounded-pill">🚀 Khám phá tri thức mới</span>
                <h1 class="display-4 fw-bold mb-4 text-dark" style="letter-spacing: -1.5px; line-height: 1.1;">
                    LMS VJU <br>
                    <span class="text-primary">Nền tảng học tập chuyên sâu</span>
                </h1>
                <p class="lead mb-4 text-secondary" style="font-size: 1.15rem; font-weight: 400; line-height: 1.6;">
                    Phát triển kỹ năng cùng những chuyên gia hàng đầu. Tham gia cùng hàng nghìn học viên đã thành công trong công việc thực tế nhờ các khóa học của chúng tôi.
                </p>
                <div class="d-flex flex-wrap gap-3 mt-4">
                    <a href="@Url.Action("Courses", "Home")" class="btn btn-dark btn-lg px-4 rounded-3 d-inline-flex align-items-center">
                        Bắt đầu học ngay
                    </a>
                    <a href="@Url.Action("About", "Home")" class="btn btn-white border border-secondary-subtle btn-lg px-4 rounded-3 d-inline-flex align-items-center text-dark btn-hover-light">
                        Tìm hiểu thêm
                    </a>
                </div>
            </div>
            <div class="col-lg-6" data-aos="fade-left">
                <div class="position-relative">
                    <!-- Ảnh chân thực, chuyên nghiệp tạo cảm giác thật sự có người thật đang học -->
                    <img src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?q=80&w=1000&auto=format&fit=crop" 
                         alt="Trải nghiệm học tập" class="img-fluid rounded-4 object-fit-cover" 
                         style="height: 500px; width: 100%; box-shadow: 0 12px 32px rgba(0,0,0,0.06);">
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Stats Section -->
<section class="py-5 border-top border-bottom bg-light">
    <div class="container py-3">
        <div class="row justify-content-center text-center gy-4">
            <div class="col-6 col-md-3" data-aos="fade-up" data-aos-delay="100">
                <div class="px-3">
                    <h2 class="display-5 fw-bold text-dark mb-1" style="letter-spacing: -1px;">@Model.TotalCourses</h2>
                    <p class="text-muted mb-0 small text-uppercase fw-medium" style="letter-spacing: 1px;">Khóa học</p>
                </div>
            </div>
            <div class="col-6 col-md-3" data-aos="fade-up" data-aos-delay="200">
                <div class="px-3">
                    <h2 class="display-5 fw-bold text-dark mb-1" style="letter-spacing: -1px;">@Model.TotalStudents+</h2>
                    <p class="text-muted mb-0 small text-uppercase fw-medium" style="letter-spacing: 1px;">Học viên</p>
                </div>
            </div>
            <div class="col-6 col-md-3" data-aos="fade-up" data-aos-delay="300">
                <div class="px-3">
                    <h2 class="display-5 fw-bold text-dark mb-1" style="letter-spacing: -1px;">@Model.TotalInstructors</h2>
                    <p class="text-muted mb-0 small text-uppercase fw-medium" style="letter-spacing: 1px;">Giảng viên</p>
                </div>
            </div>
            <div class="col-6 col-md-3" data-aos="fade-up" data-aos-delay="400">
                <div class="px-3">
                    <h2 class="display-5 fw-bold text-dark mb-1" style="letter-spacing: -1px;">1000+</h2>
                    <p class="text-muted mb-0 small text-uppercase fw-medium" style="letter-spacing: 1px;">Chứng chỉ</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Featured Courses -->
<section class="py-5 pt-lg-5 mt-4">
    <div class="container">
        <div class="text-center mb-5" data-aos="fade-up">
            <h2 class="fw-bold mb-2 text-dark" style="letter-spacing: -0.5px;">Khóa học nổi bật</h2>
            <p class="text-muted" style="font-size: 1.1rem;">Lựa chọn hàng đầu của cộng đồng học viên</p>
        </div>
        
        <div class="row g-4">
            @foreach (var course in Model.FeaturedCourses.Take(6))
            {
                <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="@(Model.FeaturedCourses.ToList().IndexOf(course) * 100)">
                    <div class="card h-100 course-card border border-light-subtle rounded-4 overflow-hidden bg-white">
                        <img src="@course.Thumbnail" class="card-img-top object-fit-cover border-bottom" alt="@course.Title" style="height: 200px;">
                        <div class="card-body d-flex flex-column p-4">
                            <div class="mb-3">
                                <span class="badge bg-light border text-dark fw-normal px-2 py-1">@course.Category.Name</span>
                            </div>
                            <h5 class="card-title fw-bold fs-5 text-dark" style="letter-spacing: -0.2px;">@course.Title</h5>
                            <p class="card-text text-secondary mb-4 flex-grow-1" style="font-size: 0.95rem; line-height: 1.5;">
                                @Html.Raw(course.Description.Length > 90 ? course.Description.Substring(0, 90) + "..." : course.Description)
                            </p>
                            <div class="d-flex justify-content-between align-items-center mt-auto pb-3 border-bottom">
                                <div>
                                    @if (course.Price == 0)
                                    {
                                        <span class="text-success fw-bold">Miễn phí</span>
                                    }
                                    else
                                    {
                                        <span class="text-dark fw-bold">@course.Price.ToString("N0") VNĐ</span>
                                    }
                                </div>
                                <div class="text-warning small">
                                    <i class="fas fa-star"></i>
                                    <i class="fas fa-star"></i>
                                    <i class="fas fa-star"></i>
                                    <i class="fas fa-star"></i>
                                    <i class="fas fa-star-half-alt"></i>
                                    <span class="text-muted ms-1 fw-medium">(4.8)</span>
                                </div>
                            </div>
                            <div class="mt-3">
                                <a href="@Url.Action("CourseDetail", "Home", new { id = course.Id })" 
                                   class="text-decoration-none text-dark fw-medium btn-link-hover d-flex align-items-center">
                                    Xem chi tiết <i class="fas fa-arrow-right ms-2 fs-6"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
        
        <div class="text-center mt-5 pt-3" data-aos="fade-up">
            <a href="@Url.Action("Courses", "Home")" class="btn btn-outline-dark px-4 py-2 rounded-3">
                Xem tất cả khóa học
            </a>
        </div>
    </div>
</section>

<!-- Categories Section -->
<section class="py-5 bg-light mb-4 mt-4">
    <div class="container py-4">
        <div class="text-center mb-5" data-aos="fade-up">
            <h2 class="fw-bold mb-2 text-dark" style="letter-spacing: -0.5px;">Khám phá theo danh mục</h2>
            <p class="text-muted" style="font-size: 1.1rem;">Lựa chọn lộ trình phù hợp với mục tiêu của bạn</p>
        </div>
        
        <div class="row g-4">
            @foreach (var category in Model.Categories.Take(8))
            {
                <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="@(Model.Categories.ToList().IndexOf(category) * 50)">
                    <a href="@Url.Action("Courses", "Home", new { categoryId = category.Id })" 
                       class="text-decoration-none">
                        <div class="card h-100 border border-light-subtle rounded-4 category-card bg-white p-2">
                            <div class="card-body d-flex align-items-center">
                                <div class="bg-light rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px; min-width: 48px;">
                                    @switch (category.Name)
                                    {
                                        case "Lập trình Web":
                                            <i class="fas fa-globe text-dark fs-5"></i>
                                            break;
                                        case "Lập trình Mobile":
                                            <i class="fas fa-mobile-alt text-dark fs-5"></i>
                                            break;
                                        case "Cơ sở dữ liệu":
                                            <i class="fas fa-database text-dark fs-5"></i>
                                            break;
                                        case "DevOps & Cloud":
                                            <i class="fas fa-cloud text-dark fs-5"></i>
                                            break;
                                        case "AI & Machine Learning":
                                            <i class="fas fa-robot text-dark fs-5"></i>
                                            break;
                                        case "Blockchain & Web3":
                                            <i class="fas fa-link text-dark fs-5"></i>
                                            break;
                                        case "Bảo mật & Hacking":
                                            <i class="fas fa-shield-alt text-dark fs-5"></i>
                                            break;
                                        default:
                                            <i class="fas fa-code text-dark fs-5"></i>
                                            break;
                                    }
                                </div>
                                <div class="text-start">
                                    <h6 class="card-title text-dark fw-bold mb-1">@category.Name</h6>
                                    <small class="text-muted d-block text-truncate" style="max-width: 140px;">@category.Description</small>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    </div>
</section>

<!-- Latest Courses -->
<section class="py-5 mb-5">
    <div class="container">
        <div class="text-center mb-5" data-aos="fade-up">
            <h2 class="fw-bold mb-2 text-dark" style="letter-spacing: -0.5px;">Khóa học vừa ra mắt</h2>
            <p class="text-muted" style="font-size: 1.1rem;">Cập nhật những kiến thức công nghệ mới thịnh hành</p>
        </div>
        
        <div class="row g-4">
            @foreach (var course in Model.LatestCourses.Take(6))
            {
                <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="@(Model.LatestCourses.ToList().IndexOf(course) * 100)">
                    <div class="card h-100 course-card border border-light-subtle rounded-4 overflow-hidden bg-white">
                        <div class="position-absolute top-0 end-0 m-3 z-3">
                            <span class="badge bg-dark fw-normal rounded-pill px-3 py-2 border shadow-sm">Mới cập nhật</span>
                        </div>
                        <img src="@course.Thumbnail" class="card-img-top object-fit-cover border-bottom" alt="@course.Title" style="height: 200px;">
                        <div class="card-body d-flex flex-column p-4">
                            <div class="mb-3">
                                <span class="badge bg-light border text-dark fw-normal px-2 py-1">@course.Category.Name</span>
                            </div>
                            <h5 class="card-title fw-bold fs-5 text-dark" style="letter-spacing: -0.2px;">@course.Title</h5>
                            <p class="card-text text-secondary mb-4 flex-grow-1" style="font-size: 0.95rem; line-height: 1.5;">
                                @Html.Raw(course.Description.Length > 90 ? course.Description.Substring(0, 90) + "..." : course.Description)
                            </p>
                            <div class="d-flex justify-content-between align-items-center mt-auto pb-3 border-bottom">
                                <div>
                                    @if (course.Price == 0)
                                    {
                                        <span class="text-success fw-bold">Miễn phí</span>
                                    }
                                    else
                                    {
                                        <span class="text-dark fw-bold">@course.Price.ToString("N0") VNĐ</span>
                                    }
                                </div>
                                <small class="text-muted fw-medium">
                                    @course.CreatedAt.ToString("dd/MM/yyyy")
                                </small>
                            </div>
                            <div class="mt-3">
                                <a href="@Url.Action("CourseDetail", "Home", new { id = course.Id })" 
                                   class="text-decoration-none text-dark fw-medium btn-link-hover d-flex align-items-center">
                                    Xem chi tiết <i class="fas fa-arrow-right ms-2 fs-6"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="py-5 bg-dark text-white rounded-4 mx-3 mx-lg-5 mb-5" style="background-image: linear-gradient(135deg, #111827 0%, #374151 100%);">
    <div class="container py-4 text-center">
        <div class="row justify-content-center">
            <div class="col-lg-7" data-aos="zoom-in">
                <h2 class="display-6 fw-bold mb-3" style="letter-spacing: -1px;">Sẵn sàng khai phá tiềm năng?</h2>
                <p class="text-light mb-4" style="font-size: 1.15rem; font-weight: 300; opacity: 0.9;">
                    Bắt đầu hành trình học tập với những giảng viên thực chiến. Chỉ một bước đăng ký để mở khóa toàn bộ tri thức.
                </p>
                <div class="d-flex flex-wrap justify-content-center gap-3 mt-2">
                    @if (!User.Identity!.IsAuthenticated)
                    {
                        <a href="/Identity/Account/Register" class="btn btn-light text-dark btn-lg px-4 rounded-3 fw-medium">
                            Đăng ký tài khoản
                        </a>
                    }
                    <a href="@Url.Action("Courses", "Home")" class="btn btn-outline-light btn-lg px-4 rounded-3 fw-medium">
                        Khám phá khóa học
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    /* Làm viền màu xám siêu mỏng cho hiện đại */
    .border-light-subtle {
        border-color: rgba(0,0,0,0.08) !important;
    }

    /* Hiệu ứng hover các thẻ card khóa học và danh mục */
    .course-card, .category-card {
        transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
    }

    .course-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 16px 24px rgba(0, 0, 0, 0.05);
        border-color: rgba(0,0,0,0.12) !important;
    }
    
    .category-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.04);
        border-color: rgba(0,0,0,0.15) !important;
    }

    /* Link xem chi tiết có mũi tên dịch chuyển ra / vào */
    .btn-link-hover i {
        transition: transform 0.2s ease;
    }
    .btn-link-hover:hover i {
        transform: translateX(4px);
    }
    
    /* Thiết kế nút bấm với background trắng */
    .btn-white {
        background-color: #fff;
    }
    .btn-hover-light:hover {
        background-color: #f8f9fa;
        color: #000;
    }
</style>
