@model CoursesViewModel
@{
    ViewData["Title"] = "Khóa học";
}

<div class="container py-5 mt-4">
    <!-- Page Header -->
    <div class="row mb-5 text-center">
        <div class="col-12" data-aos="fade-up">
            <h1 class="display-4 fw-bold mb-3" style="letter-spacing: -1px;">Khám phá khóa học</h1>
            <p class="lead text-muted" style="font-size: 1.15rem;">Khám phá hàng trđm khóa học chất lượng cao tđ các chuyên gia hàng đầu</p>
        </div>
    </div>

    <!-- Search and Filter -->
    <div class="row mb-4 justify-content-center">
        <div class="col-lg-10">
            <div class="bg-white p-3 rounded-pill border border-light-subtle shadow-sm">
                <div class="row g-2 align-items-center">
                    <div class="col-md-7">
                        <form method="get" class="d-flex w-100 position-relative">
                            <i class="fas fa-search position-absolute text-muted" style="top: 50%; transform: translateY(-50%); left: 20px;"></i>
                            <input type="text" name="search" value="@Model.SearchTerm"
                                   class="form-control form-control-lg border-0 bg-transparent ps-5 fs-6" placeholder="Tìm kiếm tên khóa học, kỹ năng..." style="box-shadow: none;">
                            <button type="submit" class="btn btn-dark rounded-pill px-4 ms-2 fw-medium">
                                Tìm kiếm
                            </button>
                        </form>
                    </div>
                    <div class="col-md-5 border-start border-light-subtle">
                        <select class="form-select form-select-lg border-0 bg-transparent fs-6" onchange="filterByCategory(this.value)" style="box-shadow: none;">
                            <option value="">Tất cả danh mục</option>
                            @foreach (var category in Model.Categories)
                            {
                                <option value="@category.Id" selected="@(Model.CurrentCategoryId == category.Id)">
                                    @category.Name
                                </option>
                            }
                        </select>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Results Info -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center bg-light rounded-3 p-3 border border-light-subtle">
                <p class="text-muted mb-0 small fw-medium">
                    Hiển thị @((Model.CurrentPage - 1) * Model.PageSize + 1) -
                    @Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalCourses)
                    trong tổng số <span class="text-dark fw-bold">@Model.TotalCourses</span> khóa học
                </p>
                <div class="d-flex align-items-center">
                    <label class="me-2 text-muted small fw-medium d-none d-sm-block">Xếp theo:</label>
                    <select class="form-select border-light-subtle rounded-3 text-dark small py-1 px-2" style="width: auto; font-size: 0.875rem;">
                        <option>Mới nhất</option>
                        <option>Phổ biđn nhất</option>
                        <option>Giá thđp đđn cao</option>
                        <option>Giá cao đđn thđp</option>
                    </select>
                </div>
            </div>
        </div>
    </div>

    <!-- Courses Grid -->
    <div class="row g-4">
        @if (Model.Courses.Any())
        {
            @foreach (var course in Model.Courses)
            {
                <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="@(Model.Courses.ToList().IndexOf(course) * 100)">
                    <div class="card h-100 course-card bg-white border border-light-subtle rounded-4 overflow-hidden">
                        <div class="position-relative">
                            <img src="@course.Thumbnail" class="card-img-top object-fit-cover border-bottom" alt="@course.Title" style="height: 200px;">
                            @if (course.Price == 0)
                            {
                                <span class="position-absolute top-0 end-0 m-3 badge bg-success fw-normal px-2 py-1 shadow-sm rounded-pill">Miễn phí</span>
                            }
                            else
                            {
                                <span class="position-absolute top-0 end-0 m-3 badge bg-dark text-white fw-medium px-3 py-1 shadow-sm rounded-pill">@course.Price.ToString("N0") đ</span>
                            }
                        </div>
                        <div class="card-body d-flex flex-column p-4">
                            <div class="mb-3 d-flex flex-wrap gap-1">
                                <span class="badge bg-light border text-dark fw-normal px-2 py-1">@course.Category.Name</span>
                                <span class="badge bg-light border text-secondary fw-normal px-2 py-1">@course.Status</span>
                            </div>
                            <h5 class="card-title fw-bold fs-5 text-dark mb-2" style="letter-spacing: -0.2px;">@course.Title</h5>
                            <p class="card-text text-secondary flex-grow-1" style="font-size: 0.95rem; line-height: 1.5;">
                                @Html.Raw(course.Description.Length > 120 ? course.Description.Substring(0, 120) + "..." : course.Description)
                            </p>

                            <!-- Course Stats -->
                            <div class="d-flex justify-content-between text-muted small py-3 border-top border-bottom border-light-subtle mb-3">
                                <div>
                                    <i class="fas fa-users me-1 text-secondary"></i>
                                    @course.Enrollments.Count()
                                </div>
                                <div>
                                    <i class="fas fa-book-open me-1 text-secondary"></i>
                                    @course.Chapters.Count() bài
                                </div>
                                <div>
                                    <i class="fas fa-star text-warning me-1"></i>
                                    4.8 (120)
                                </div>
                            </div>

                            <!-- Action Buttons -->
                            <div class="mt-auto">
                                <a href="@Url.Action("CourseDetail", "Home", new { id = course.Id })"
                                   class="btn btn-outline-dark w-100 rounded-3 fw-medium">
                                    Xem chi tiết
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <div class="bg-light p-5 rounded-4 border border-light-subtle" data-aos="fade-up">
                    <div class="d-inline-flex bg-white rounded-circle align-items-center justify-content-center border shadow-sm mb-4" style="width: 80px; height: 80px;">
                        <i class="fas fa-search fs-3 text-muted"></i>
                    </div>
                    <h3 class="fw-bold mb-2">Không tđm thđy khóa học nào</h3>
                    <p class="text-muted mb-4">Hãy thử tđm kiđm vđi tđ khóa khác hoặc chọn cđc danh mục khác.</p>
                    <a href="@Url.Action("Courses", "Home")" class="btn btn-dark rounded-pill px-4">
                        <i class="fas fa-redo-alt me-2 small"></i>Xem tất cả khóa học
                    </a>
                </div>
            </div>
        }
    </div>

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <div class="row mt-5">
            <div class="col-12">
                <nav aria-label="Course pagination">
                    <ul class="pagination justify-content-center border-0">
                        @if (Model.CurrentPage > 1)
                        {
                            <li class="page-item">
                                <a class="page-link shadow-sm border border-light-subtle rounded-3 text-dark mx-1" href="@Url.Action("Courses", new {
                                    page = Model.CurrentPage - 1,
                                    categoryId = Model.CurrentCategoryId,
                                    search = Model.SearchTerm
                                })">
                                    <i class="fas fa-chevron-left small"></i>
                                </a>
                            </li>
                        }

                        @for (int i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link shadow-sm @(i == Model.CurrentPage ? "bg-dark text-white border-dark" : "border-light-subtle text-dark border") rounded-3 mx-1 fw-medium" href="@Url.Action("Courses", new {
                                    page = i,
                                    categoryId = Model.CurrentCategoryId,
                                    search = Model.SearchTerm
                                })">@i</a>
                            </li>
                        }

                        @if (Model.CurrentPage < Model.TotalPages)
                        {
                            <li class="page-item">
                                <a class="page-link shadow-sm border border-light-subtle rounded-3 text-dark mx-1" href="@Url.Action("Courses", new {
                                    page = Model.CurrentPage + 1,
                                    categoryId = Model.CurrentCategoryId,
                                    search = Model.SearchTerm
                                })">
                                    <i class="fas fa-chevron-right small"></i>
                                </a>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        </div>
    }
</div>

<style>
    .border-light-subtle {
        border-color: rgba(0,0,0,0.08) !important;
    }
    
    .course-card {
        transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
    }
    .course-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 16px 24px rgba(0, 0, 0, 0.05);
        border-color: rgba(0,0,0,0.12) !important;
    }

    .pagination .page-link {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .pagination .active .page-link {
        background-color: #212529 !important;
        border-color: #212529 !important;
        color: #fff !important;
    }
    .pagination .page-link:hover:not(.active .page-link) {
        background-color: #f8f9fa;
        color: #000;
    }
</style>

<script>
    function filterByCategory(categoryId) {
        const url = new URL(window.location);
        if (categoryId) {
            url.searchParams.set('categoryId', categoryId);
        } else {
            url.searchParams.delete('categoryId');
        }
        url.searchParams.delete('page'); // Reset to first page
        window.location.href = url.toString();
    }
</script>
